type testAudioBackend struct {
	listenerPos voplay.Vec3
	listenerForward voplay.Vec3
	listenerUp voplay.Vec3
	playedClip voplay.AudioClipID
	playedPos voplay.Vec3
	playedVolume float64
	playedRefDist float64
	playedMaxDist float64
	nextSourceID int
	created []int
	positions map[int]voplay.Vec3
	sourceVolumes map[int]float64
	sourcePitches map[int]float64
	removed []int
	updateCalls int
}

func (a *testAudioBackend) SetListener(position, forward, up voplay.Vec3) {
	a.listenerPos = position
	a.listenerForward = forward
	a.listenerUp = up
}

func (a *testAudioBackend) PlaySound3D(clip voplay.AudioClipID, pos voplay.Vec3, volume, refDistance, maxDistance float64) {
	a.playedClip = clip
	a.playedPos = pos
	a.playedVolume = volume
	a.playedRefDist = refDistance
	a.playedMaxDist = maxDistance
}

func (a *testAudioBackend) CreateSource3D(clip voplay.AudioClipID, pos voplay.Vec3, volume, refDistance, maxDistance float64) (voplay.AudioSourceID, error) {
	id := voplay.AudioSourceID(a.nextSourceID)
	a.nextSourceID++
	a.created = append(a.created, int(id))
	a.positions[int(id)] = pos
	return id, nil
}

func (a *testAudioBackend) UpdateSpatial() {
	a.updateCalls++
}

func (a *testAudioBackend) SetSource3DPos(id voplay.AudioSourceID, pos voplay.Vec3) {
	a.positions[int(id)] = pos
}

func (a *testAudioBackend) SetSource3DParams(id voplay.AudioSourceID, volume, pitch float64) {
	if a.sourceVolumes == nil {
		a.sourceVolumes = map[int]float64{}
	}
	if a.sourcePitches == nil {
		a.sourcePitches = map[int]float64{}
	}
	a.sourceVolumes[int(id)] = volume
	a.sourcePitches[int(id)] = pitch
}

func (a *testAudioBackend) RemoveSource3D(id voplay.AudioSourceID) {
	a.removed = append(a.removed, int(id))
	delete(a.positions, int(id))
}

