	a.modelInfoCalls++
	if model == voplay.ModelID(901) {
		return scene3d.AnimationModelInfo{HasSkeleton: true, JointCount: 24, Clips: []scene3d.AnimationClipInfo{{Name: "idle", Duration: 1.0}, {Name: "run", Duration: 0.5}}}
