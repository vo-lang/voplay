		strconv.Itoa(frame.GpuQueue.InFlightSubmits) +
		",\"rendererSubmitFrameMs\":" +
		perfSummaryJSONFloat(frame.RendererCpu.SubmitFrameMs) +
		",\"rendererDecodeMs\":" +
		perfSummaryJSONFloat(frame.RendererCpu.DecodeMs) +
