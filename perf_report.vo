package voplay

import (
	"strconv"
)

	// PerfSummaryFixedStats carries product-owned fixed-step timing alongside engine perf facts.
type PerfSummaryFixedStats struct {
	TotalMs float64
	PeakTotalMs float64
	SlowFrames int
	Frames int
	SlowestPhase string
	SlowestPhaseMs float64
	MaxSlowFrames int
}

func EncodePerfSummaryReport(source string, frame int, snapshot PerfSnapshot, window PerfWindowSummary, status string, gate PerfGateResult, fixed PerfSummaryFixedStats, screen ScreenMetrics) string {
	current := snapshot.Current
	renderer := current.RendererCpu
	workload := current.RendererWorkload
	gpu := current.GpuQueue
	hist := snapshot.SlowHistogram
	latestSpike := perfSummaryLatestSpike(snapshot)
	windowWorst := snapshot.WindowWorstFrame
	screenMPixels := float64(screen.PixelWidth * screen.PixelHeight) / 1000000.0
	return "{" + "\"schemaVersion\":1" + ",\"source\":" + perfSummaryJSONString(source) +
		",\"kind\":\"perf-summary\"" +
		",\"frame\":" +
		strconv.Itoa(frame) +
		",\"mode\":" +
		perfSummaryJSONString(snapshot.Mode) +
		",\"status\":" +
		perfSummaryJSONString(status) +
		",\"gatePassed\":" +
		perfSummaryJSONBool(gate.Passed) +
		",\"failure\":" +
		perfSummaryJSONString(gate.PrimaryFailure) +
		",\"gate\":{" +
		"\"checkedFrames\":" +
		strconv.Itoa(gate.CheckedFrames) +
		",\"slowFrames\":" +
		strconv.Itoa(gate.SlowFrames) +
		",\"maxSlowFrames\":" +
		strconv.Itoa(fixed.MaxSlowFrames) +
		",\"frameP99Ms\":" +
		perfSummaryJSONFloat(gate.FrameP99Ms) +
		",\"frameMaxMs\":" +
		perfSummaryJSONFloat(gate.FrameMaxMs) +
		",\"activeWorkP90Ms\":" +
		perfSummaryJSONFloat(gate.ActiveWorkP90Ms) +
		",\"activeWorkP99Ms\":" +
		perfSummaryJSONFloat(gate.ActiveWorkP99Ms) +
		"}" +
		",\"targetHz\":" +
		strconv.Itoa(snapshot.TargetHz) +
		",\"budgetMs\":" +
		perfSummaryJSONFloat(snapshot.BudgetMs) +
		",\"screen\":{" +
		"\"cssWidth\":" +
		strconv.Itoa(screen.Width) +
		",\"cssHeight\":" +
		strconv.Itoa(screen.Height) +
		",\"pixelWidth\":" +
		strconv.Itoa(screen.PixelWidth) +
		",\"pixelHeight\":" +
		strconv.Itoa(screen.PixelHeight) +
		",\"devicePixelRatio\":" +
		perfSummaryJSONFloat(screen.DevicePixelRatio) +
		",\"mpix\":" +
		perfSummaryJSONFloat(screenMPixels) +
		"}" +
		",\"window\":{" +
		"\"frames\":" +
		strconv.Itoa(window.Frames) +
		",\"slowFrames\":" +
		strconv.Itoa(window.SlowFrames) +
		",\"frameP50Ms\":" +
		perfSummaryJSONFloat(window.FrameP50Ms) +
		",\"frameP90Ms\":" +
		perfSummaryJSONFloat(window.FrameP90Ms) +
		",\"frameP99Ms\":" +
		perfSummaryJSONFloat(window.FrameP99Ms) +
		",\"frameMaxMs\":" +
		perfSummaryJSONFloat(window.FrameMaxMs) +
		",\"gameCpuP90Ms\":" +
		perfSummaryJSONFloat(window.GameCpuP90Ms) +
		",\"drawEncodeP90Ms\":" +
		perfSummaryJSONFloat(window.DrawEncodeP90Ms) +
		",\"renderLoopP90Ms\":" +
		perfSummaryJSONFloat(window.RenderLoopP90Ms) +
		",\"renderWorkP90Ms\":" +
		perfSummaryJSONFloat(window.RenderWorkP90Ms) +
		",\"renderSubmitP90Ms\":" +
		perfSummaryJSONFloat(window.RenderSubmitP90Ms) +
		",\"gpuWorkDoneP90Ms\":" +
		perfSummaryJSONFloat(window.GpuWorkDoneP90Ms) +
		",\"activeWorkP90Ms\":" +
		perfSummaryJSONFloat(window.ActiveWorkP90Ms) +
		",\"activeWorkP99Ms\":" +
		perfSummaryJSONFloat(window.ActiveWorkP99Ms) +
		",\"hudP90Ms\":" +
		perfSummaryJSONFloat(window.HudP90Ms) +
		"}" +
		",\"histogram\":{" +
		"\"leBudget\":" +
		strconv.Itoa(hist.LeBudget) +
		",\"le12Ms\":" +
		strconv.Itoa(hist.Le12Ms) +
		",\"le16Ms\":" +
		strconv.Itoa(hist.Le16Ms) +
		",\"le25Ms\":" +
		strconv.Itoa(hist.Le25Ms) +
		",\"le33Ms\":" +
		strconv.Itoa(hist.Le33Ms) +
		",\"le50Ms\":" +
		strconv.Itoa(hist.Le50Ms) +
		",\"le100Ms\":" +
		strconv.Itoa(hist.Le100Ms) +
		",\"gt100Ms\":" +
		strconv.Itoa(hist.Gt100Ms) +
		"}" +
		",\"classification\":{" +
		"\"primaryCause\":" +
		perfSummaryJSONString(current.Classification.PrimaryCause) +
		",\"secondaryCause\":" +
		perfSummaryJSONString(current.Classification.SecondaryCause) +
		",\"mixed\":" +
		perfSummaryJSONBool(current.Classification.Mixed) +
		",\"latestSpikeFrame\":" +
		strconv.Itoa(latestSpike.FrameId) +
		",\"latestSpikeMs\":" +
		perfSummaryJSONFloat(latestSpike.FrameMs) +
		",\"latestSpikeCause\":" +
		perfSummaryJSONString(latestSpike.PrimaryCause) +
		",\"windowWorstFrame\":" +
		strconv.Itoa(windowWorst.FrameId) +
		",\"windowWorstMs\":" +
		perfSummaryJSONFloat(windowWorst.FrameMs) +
		",\"windowWorstCause\":" +
		perfSummaryJSONString(windowWorst.Classification.PrimaryCause) +
		",\"latestSpike\":" +
		perfSummarySpikeJSON(latestSpike) +
		",\"windowWorst\":" +
		perfSummaryFrameBreakdownJSON(windowWorst) +
		"}" +
		",\"current\":{" +
		"\"frameMs\":" +
		perfSummaryJSONFloat(current.FrameMs) +
		",\"gameCpuMs\":" +
		perfSummaryJSONFloat(current.GameCpu.TotalMs) +
		",\"fixedSteps\":" +
		strconv.Itoa(current.GameCpu.FixedSteps) +
		",\"drawEncodeMs\":" +
		perfSummaryJSONFloat(current.GameCpu.DrawEncodeMs) +
		",\"renderLoopMs\":" +
		perfSummaryJSONFloat(current.RenderWorker.LoopTotalMs) +
		",\"displayPulseMs\":" +
		perfSummaryJSONFloat(current.RenderWorker.DisplayPulseMs) +
		",\"paceWaitMs\":" +
		perfSummaryJSONFloat(current.RenderWorker.PaceWaitMs) +
		",\"frameDivisor\":" +
		strconv.Itoa(current.RenderWorker.FrameDivisor) +
		",\"replyWaitMs\":" +
		perfSummaryJSONFloat(current.RenderWorker.ReplyWaitMs) +
		",\"requestSendMs\":" +
		perfSummaryJSONFloat(current.RenderWorker.RequestSendMs) +
		",\"requestEncodeMs\":" +
		perfSummaryJSONFloat(current.RenderWorker.RequestEncodeMs) +
		",\"requestPortSendMs\":" +
		perfSummaryJSONFloat(current.RenderWorker.RequestPortSendMs) +
		",\"submitCpuMs\":" +
		perfSummaryJSONFloat(current.RenderWorker.SubmitCpuMs) +
		",\"renderWorkMs\":" +
		perfSummaryJSONFloat(current.RenderWorker.WorkMs) +
		",\"gpuWorkDoneMs\":" +
		perfSummaryJSONFloat(gpu.SubmittedWorkDoneMs) +
		",\"gpuQueueDepth\":" +
		perfSummaryJSONString(gpu.QueueDepthClass) +
		"}" +
		",\"renderer\":{" +
		"\"submitFrameMs\":" +
		perfSummaryJSONFloat(renderer.SubmitFrameMs) +
		",\"decodeMs\":" +
		perfSummaryJSONFloat(renderer.DecodeMs) +
		",\"sceneUpdateMs\":" +
		perfSummaryJSONFloat(renderer.SceneUpdateMs) +
		",\"depthPassMs\":" +
		perfSummaryJSONFloat(renderer.DepthPassMs) +
		",\"shadowPassMs\":" +
		perfSummaryJSONFloat(renderer.ShadowPassMs) +
		",\"mainPassMs\":" +
		perfSummaryJSONFloat(renderer.MainPassMs) +
		",\"mainPassSetupMs\":" +
		perfSummaryJSONFloat(renderer.MainPassSetupMs) +
		",\"mainSkyboxMs\":" +
		perfSummaryJSONFloat(renderer.MainSkyboxMs) +
		",\"mainModelMs\":" +
		perfSummaryJSONFloat(renderer.MainModelMs) +
		",\"mainPrimitiveMs\":" +
		perfSummaryJSONFloat(renderer.MainPrimitiveMs) +
		",\"mainPassCloseMs\":" +
		perfSummaryJSONFloat(renderer.MainPassCloseMs) +
		",\"waterPassMs\":" +
		perfSummaryJSONFloat(renderer.WaterPassMs) +
		",\"postPassMs\":" +
		perfSummaryJSONFloat(renderer.PostPassMs) +
		",\"overlayPassMs\":" +
		perfSummaryJSONFloat(renderer.OverlayPassMs) +
		",\"queueSubmitCpuMs\":" +
		perfSummaryJSONFloat(renderer.QueueSubmitCpuMs) +
		",\"presentCpuMs\":" +
		perfSummaryJSONFloat(renderer.PresentCpuMs) +
		"}" +
		",\"workload\":{" +
		"\"drawCalls\":" +
		strconv.Itoa(workload.DrawCalls) +
		",\"modelDraws\":" +
		strconv.Itoa(workload.ModelDraws) +
		",\"primitiveDraws\":" +
		strconv.Itoa(workload.PrimitiveDraws) +
		",\"waterDraws\":" +
		strconv.Itoa(workload.WaterDraws) +
		",\"waterInstances\":" +
		strconv.Itoa(workload.WaterInstances) +
		",\"waterTriangles\":" +
		strconv.Itoa(workload.WaterTriangles) +
		",\"instancedBatches\":" +
		strconv.Itoa(workload.InstancedBatches) +
		",\"shadowCascades\":" +
		strconv.Itoa(workload.ShadowCascades) +
		",\"primitiveChunks\":" +
		strconv.Itoa(workload.PrimitiveChunks) +
		",\"postEffects\":" +
		strconv.Itoa(workload.PostEffects) +
		",\"instances\":" +
		strconv.Itoa(workload.Instances) +
		",\"triangles\":" +
		strconv.Itoa(workload.Triangles) +
		",\"uploadBytes\":" +
		strconv.Itoa(workload.UploadBytes) +
		",\"bufferCreates\":" +
		strconv.Itoa(workload.BufferCreates) +
		",\"bindGroupCreates\":" +
		strconv.Itoa(workload.BindGroupCreates) +
		",\"textureUploads\":" +
		strconv.Itoa(workload.TextureUploads) +
		",\"residentChunkRebuilds\":" +
		strconv.Itoa(workload.ResidentChunkRebuilds) +
		",\"diagnosticFlags\":" +
		strconv.Itoa(workload.DiagnosticFlags) +
