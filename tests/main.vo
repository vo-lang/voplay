func testScene3DSpawnRollback() {
	freed := &intList{}
	mb := &testFreeModelBackend{freed: freed}
	mb.prev = voplay.SetModelBackend(mb)
	defer voplay.SetModelBackend(mb.prev)
	pb := &testScene3DPhysicsBackend{panicOnSpawn: true}
	prevPhys := scene3d.SetPhysicsBackend(pb)
	defer scene3d.SetPhysicsBackend(prevPhys)
	s := scene3d.New()
	_, didPanic := capturePanic(func() {
		s.Spawn(scene3d.EntityDesc{OwnedModel: voplay.ModelID(701), Physics: &scene3d.Physics{Type: scene3d.Dynamic, Collider: scene3d.Box(1, 1, 1), Layer: voplay.CollisionLayerDefault, Mask: voplay.CollisionMaskAll}})
	})
	assert(didPanic, "scene3d spawn rollback panics on backend failure")
	assert(s.EntityCount() == 0, "scene3d spawn rollback leaves no entity behind")
	assert(!s.HasPhysics(), "scene3d spawn rollback destroys newly created physics world")
	assert(pb.initCalls == 1, "scene3d spawn rollback initializes physics once")
	assert(len(pb.destroyBodies) == 1 && pb.destroyBodies[0] == 1, "scene3d spawn rollback destroys allocated body")
	assert(len(pb.destroyWorlds) == 1 && pb.destroyWorlds[0] == 91, "scene3d spawn rollback destroys allocated world")
	assert(len(freed.items) == 1 && freed.items[0] == 701, "scene3d spawn rollback frees owned model")
	recovered := s.Spawn(scene3d.EntityDesc{Tag: "recovered"})
	assert(recovered.ID() == 1, "scene3d spawn rollback restores next entity id")
	s.Close()
	assert(len(pb.destroyWorlds) == 1, "scene3d close after rolled back spawn does not destroy absent world twice")
}

func testScene3DTintSemantics() {
	s := scene3d.New()
	defaultTint := s.Spawn(scene3d.EntityDesc{Tag: "default"})
	assert(defaultTint.Tint == voplay.White, "scene3d default tint is white")
	assert(defaultTint.Material == (voplay.MaterialDesc{}), "scene3d default material preserves source material")
	explicitTint := voplay.Color{R: 0.2, G: 0.4, B: 0.6, A: 0.8}
	tinted := s.Spawn(scene3d.EntityDesc{Tag: "tinted", Tint: explicitTint})
	assert(tinted.Tint == explicitTint, "scene3d explicit non-zero tint is preserved")
	assert(tinted.Material.BaseColor == explicitTint, "scene3d tint feeds material base color")
	transparent := s.Spawn(scene3d.EntityDesc{Tag: "transparent", Tint: voplay.Color{}, TintSet: true})
	assert(transparent.Tint == (voplay.Color{}), "scene3d explicit zero tint is preserved when TintSet")
	assert(transparent.Material.BaseColor == (voplay.Color{}), "scene3d explicit transparent tint feeds material")
	material := voplay.MaterialDesc{BaseColor: voplay.Hex(0x3366cc), Albedo: voplay.TextureID(42), Normal: voplay.TextureID(43), MetallicRoughness: voplay.TextureID(46), Emissive: voplay.TextureID(44), Roughness: 0.7, Metallic: 0.2, NormalScale: 0.65, UVScale: 2.5, ToonRamp: voplay.TextureID(45), EmissiveColor: voplay.Color{R: 0.1, G: 0.2, B: 0.3, A: 1}, ShadingMode: voplay.MaterialShadingToon, WrapMode: voplay.MaterialWrapClamp, FilterMode: voplay.MaterialFilterNearest}
	materialEntity := s.Spawn(scene3d.EntityDesc{Tag: "material", Material: material})
	assert(materialEntity.Material.BaseColor == material.BaseColor, "scene3d explicit material base color")
	assert(materialEntity.Material.Albedo == material.Albedo, "scene3d explicit material albedo")
	assert(materialEntity.Material.Normal == material.Normal, "scene3d explicit material normal map")
	assert(materialEntity.Material.MetallicRoughness == material.MetallicRoughness, "scene3d explicit material metallic-roughness map")
	assert(materialEntity.Material.Emissive == material.Emissive, "scene3d explicit material emissive map")
	assert(materialEntity.Material.ToonRamp == material.ToonRamp, "scene3d explicit material toon ramp")
	assertFloatNear(materialEntity.Material.UVScale, 2.5, 0.000001, "scene3d explicit material uv scale")
	assertFloatNear(materialEntity.Material.Roughness, 0.7, 0.000001, "scene3d explicit material roughness")
	assertFloatNear(materialEntity.Material.Metallic, 0.2, 0.000001, "scene3d explicit material metallic")
	assertFloatNear(materialEntity.Material.NormalScale, 0.65, 0.000001, "scene3d explicit material normal scale")
	assert(materialEntity.Material.EmissiveColor == material.EmissiveColor, "scene3d explicit material emissive color")
	assert(materialEntity.Material.ShadingMode == voplay.MaterialShadingToon, "scene3d explicit material toon mode")
	assert(materialEntity.Material.WrapMode == voplay.MaterialWrapClamp, "scene3d explicit material sampler wrap")
	assert(materialEntity.Material.FilterMode == voplay.MaterialFilterNearest, "scene3d explicit material sampler filter")
	s.Close()
}

func testScene3DPicking() {
	scene3DPickTestBounds = map[int]voplay.AABB{1: {Min: voplay.Vec3{X: -1, Y: -1, Z: -1}, Max: voplay.Vec3{X: 1, Y: 1, Z: 1}}, 2: {Min: voplay.Vec3{X: -1, Y: -1, Z: -1}, Max: voplay.Vec3{X: 1, Y: 1, Z: 1}}, 3: {Min: voplay.Vec3{X: -1, Y: -1, Z: -1}, Max: voplay.Vec3{X: 1, Y: 1, Z: 1}}}
	scene3DPickTestBoundsPresent = map[int]bool{1: true, 2: true, 3: true}
	scene3DPickTestBoundsCalls = 0
	prevBackend := voplay.SetModelBackend(&testPickModelBackend{})
	defer func() {
		voplay.SetModelBackend(prevBackend)
		scene3DPickTestBounds = nil
		scene3DPickTestBoundsPresent = nil
		scene3DPickTestBoundsCalls = 0
	}()
	s := scene3d.New()
	near := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(1), Position: voplay.Vec3{Z: 0}, Tag: "near"})
	far := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(2), Position: voplay.Vec3{Z: -6}, Tag: "far"})
	_ = s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(3), Tag: "hidden", PickMode: scene3d.PickDisabled})
	origin := voplay.Vec3{Z: 5}
	dir := voplay.Vec3{Z: -1}
	hit := s.PickRay(origin, dir, 20)
	assert(hit != nil, "scene3d pick ray returns hit")
	assert(hit.Entity == near, "scene3d pick ray returns nearest visible pickable entity")
	assertFloatNear(hit.Distance, 4.0, 0.000001, "scene3d pick ray distance uses nearest face")
	all := s.PickAllRay(origin, dir, 20)
	assert(len(all) == 2, "scene3d pick all ray returns visible pickable hits")
	assert(all[0].Entity == near, "scene3d pick all ray sorts nearest first")
	assert(all[1].Entity == far, "scene3d pick all ray includes farther hit second")
	filtered := s.PickRayFiltered(origin, dir, 20, func(e *scene3d.Entity) bool {
		return e.Tag == "far"
	})
	assert(filtered != nil && filtered.Entity == far, "scene3d pick ray filter selects matching entity")
	assert(scene3DPickTestBoundsCalls == 2, "scene3d pick caches bounds per model and skips disabled entities")
	s.Close()
}

func testScene3DAttachedSpatialAudio() {
	au := &testAudioBackend{nextSourceID: 1, positions: map[int]voplay.Vec3{}}
	prevBackend := voplay.SetAudioBackend(au)
	defer voplay.SetAudioBackend(prevBackend)
	s := scene3d.New()
	s.Camera.Position = voplay.Vec3{X: 0, Y: 2, Z: 5}
	s.Camera.Target = voplay.Vec3{X: 0, Y: 2, Z: 0}
	s.Camera.Up = voplay.Vec3{Y: 1}
	e := s.Spawn(scene3d.EntityDesc{Position: voplay.Vec3{X: 1, Y: 2, Z: 3}, Tag: "speaker"})
	e.PlaySound3D(voplay.AudioClipID(7), 0.5)
	assert(au.playedClip == voplay.AudioClipID(7), "scene3d entity play sound forwards clip")
	assertVec3Near(au.playedPos, voplay.Vec3{X: 1, Y: 2, Z: 3}, 0.000001, "scene3d entity play sound forwards position")
	assertFloatNear(au.playedVolume, 0.5, 0.000001, "scene3d entity play sound forwards volume")
	assertFloatNear(au.playedRefDist, 1.0, 0.000001, "scene3d entity play sound uses default ref distance")
	assertFloatNear(au.playedMaxDist, 50.0, 0.000001, "scene3d entity play sound uses default max distance")
	source, err := e.AttachAudioSource(voplay.AudioClipID(8), 0.7, 2.0, 30.0)
	assert(err == nil, "scene3d attach audio source err")
	assert(source == voplay.AudioSourceID(1), "scene3d attach audio source returns created id")
	e.SetPosition(voplay.Vec3{X: 4, Y: 5, Z: 6})
	s.UpdateAudio()
	assert(au.updateCalls == 1, "scene3d update audio calls backend update")
	assertVec3Near(au.positions[1], voplay.Vec3{X: 4, Y: 5, Z: 6}, 0.000001, "scene3d update audio syncs attached source position")
	assertVec3Near(au.listenerPos, s.Camera.Position, 0.000001, "scene3d update audio forwards listener position")
	assertVec3Near(au.listenerForward, voplay.Vec3{X: 0, Y: 0, Z: -1}, 0.000001, "scene3d update audio forwards listener forward")
	assertVec3Near(au.listenerUp, s.Camera.Up, 0.000001, "scene3d update audio forwards listener up")
	e.RemoveAudioSource(source)
	assert(len(au.removed) == 1 && au.removed[0] == 1, "scene3d remove audio source forwards removal")
	_, didPanic := capturePanic(func() {
		e.RemoveAudioSource(source)
	})
	assert(didPanic, "scene3d removing missing audio source panics")
	source2, err := e.AttachAudioSource(voplay.AudioClipID(9), 1.0, 1.0, 10.0)
	assert(err == nil, "scene3d second attach audio source err")
	assert(source2 == voplay.AudioSourceID(2), "scene3d second attach audio source returns next id")
	s.Destroy(e)
	assert(len(au.removed) == 2 && au.removed[1] == 2, "scene3d destroy removes attached audio sources")
	s.Close()
}

func testScene3DVehicleAudioHelpers() {
	au := &testAudioBackend{nextSourceID: 10, positions: map[int]voplay.Vec3{}, sourceVolumes: map[int]float64{}, sourcePitches: map[int]float64{}}
	prevBackend := voplay.SetAudioBackend(au)
	defer voplay.SetAudioBackend(prevBackend)
	s := scene3d.New()
	e := s.Spawn(scene3d.EntityDesc{Position: voplay.Vec3{X: 2, Y: 3, Z: 4}, Tag: "kart-audio"})
	audio, err := scene3d.AttachVehicleAudio(e, scene3d.VehicleAudioClips{Engine: 1, Skid: 2, Boost: 3, Collision: 4, Surface: 5}, scene3d.VehicleAudioConfig{EngineMaxSpeed: 40})
	assert(err == nil, "scene3d vehicle audio attach")
	assert(len(au.created) == 4, "scene3d vehicle audio creates looping sources")
	state := audio.Update(scene3d.VehicleAudioInput{Speed: 20, LateralSlip: 0.05})
	assert(state.EnginePitch > 0.72 && state.EnginePitch < 1.85, "scene3d vehicle audio engine pitch follows speed")
	assertFloatNear(au.sourcePitches[10], state.EnginePitch, 0.000001, "scene3d vehicle audio applies engine pitch")
	assertFloatNear(state.SkidVolume, 0, 0.000001, "scene3d vehicle audio skid silent below threshold")
	state = audio.Update(scene3d.VehicleAudioInput{RPM: 6000, MaxRPM: 8000, LateralSlip: 0.9, Boost: true, SurfaceAmount: 0.5, CollisionImpulse: 0.6})
	assert(state.EnginePitch > au.sourcePitches[10] || state.EnginePitch > 1.4, "scene3d vehicle audio rpm drives engine pitch")
	assert(state.SkidVolume > 0, "scene3d vehicle audio skid audible above threshold")
	assertFloatNear(au.sourceVolumes[11], state.SkidVolume, 0.000001, "scene3d vehicle audio applies skid volume")
	assertFloatNear(au.sourceVolumes[12], state.BoostVolume, 0.000001, "scene3d vehicle audio applies boost volume")
	assertFloatNear(au.sourceVolumes[13], state.SurfaceVolume, 0.000001, "scene3d vehicle audio applies surface volume")
	assert(au.playedClip == voplay.AudioClipID(4), "scene3d vehicle audio collision hook plays clip")
	e.SetPosition(voplay.Vec3{X: 8, Y: 9, Z: 10})
	s.UpdateAudio()
	assertVec3Near(au.positions[10], e.Position(), 0.000001, "scene3d vehicle audio source follows entity")
	audio.Destroy()
	assert(len(au.removed) == 4, "scene3d vehicle audio destroy removes loops")
	s.Close()
}

func testPrimitive3DModuleContract() {
	pb := &testPrimitiveMeshBackend{}
	prevPrimitiveBackend := voplay.SetPrimitiveMeshBackend(pb)
	defer voplay.SetPrimitiveMeshBackend(prevPrimitiveBackend)
	shapes := primitive3d.NewShapeRegistry()
	rounded := shapes.Shape(primitive3d.ShapeDesc{Kind: primitive3d.ShapeRoundedBox})
	roundedAgain := shapes.Shape(primitive3d.ShapeDesc{Kind: primitive3d.ShapeRoundedBox})
	assert(rounded == roundedAgain, "primitive3d shape registry reuses equal shape desc")
	roundedModel := shapes.Model(rounded)
	roundedModelAgain := shapes.Model(roundedAgain)
	assert(roundedModel == roundedModelAgain, "primitive3d shape registry reuses generated model")
	assert(pb.roundedBoxCalls == 1, "primitive3d rounded box creates one shared rounded model")
	sphere := shapes.Shape(primitive3d.ShapeDesc{Kind: primitive3d.ShapeSphere, Segments: 12})
	sphereAgain := shapes.Shape(primitive3d.ShapeDesc{Kind: primitive3d.ShapeSphere, Segments: 12})
	assert(sphere == sphereAgain, "primitive3d sphere shape desc is cached")
	shapes.Model(sphere)
	shapes.Model(sphereAgain)
	assert(pb.sphereCalls == 1, "primitive3d sphere model is cached")
	assert(pb.lastSphereSegments == 12, "primitive3d sphere forwards segment count")
	cone := shapes.Shape(primitive3d.ShapeDesc{Kind: primitive3d.ShapeCone, Segments: 9})
	wedge := shapes.Shape(primitive3d.ShapeDesc{Kind: primitive3d.ShapeWedge})
	shapes.Model(cone)
	shapes.Model(wedge)
	assert(pb.coneCalls == 1, "primitive3d cone uses cone mesh backend")
	assert(pb.wedgeCalls == 1, "primitive3d wedge uses wedge mesh backend")
	assert(shapes.Revision() == 4, "primitive3d shape registry revision changes on new shape")
	assert(len(shapes.Entries()) == 4 && shapes.Entries()[0].ID == rounded, "primitive3d shape registry exposes table entries")
	materials := primitive3d.NewMaterialPalette()
	red := materials.Material(primitive3d.MaterialDesc{Preset: primitive3d.MaterialToyPlastic, Base: voplay.MaterialColor(voplay.Red), Name: "red plastic"})
	redAgain := materials.Material(primitive3d.MaterialDesc{Preset: primitive3d.MaterialToyPlastic, Base: voplay.MaterialColor(voplay.Red), Name: "debug name ignored"})
	assert(red == redAgain, "primitive3d material palette reuses identical material entries")
	assert(materials.Revision() == 1, "primitive3d material palette revision changes on new material")
	assert(len(materials.Entries()) == 1 && materials.Entries()[0].ID == red, "primitive3d material palette exposes table entries")
	rubber := materials.Material(primitive3d.MaterialDesc{Preset: primitive3d.MaterialRubber})
	assert(materials.Desc(rubber).Roughness > 0.8, "primitive3d rubber preset is high roughness")
	builder := primitive3d.NewBuilder(primitive3d.BuilderDesc{Kind: primitive3d.StaticLayer, Chunking: primitive3d.ChunkingDesc{CellSize: 4}, Name: "builder_contract"})
	builderMat := primitive3d.MaterialDesc{Preset: primitive3d.MaterialToyPlastic, Base: voplay.MaterialColor(voplay.Red)}
	builder.AddPart(primitive3d.PartDesc{Shape: primitive3d.ShapeDesc{Kind: primitive3d.ShapeRoundedBox, BevelRadius: 0.1}, Material: builderMat, Position: voplay.Vec3{X: 0}})
	builder.AddPart(primitive3d.PartDesc{Shape: primitive3d.ShapeDesc{Kind: primitive3d.ShapeRoundedBox, BevelRadius: 0.1}, Material: builderMat, Position: voplay.Vec3{X: 6}})
	builderLayer := builder.Build()
	assert(builder.Shapes().Revision() == 1, "primitive3d builder reuses equal shape descs")
	assert(builder.Materials().Revision() == 1, "primitive3d builder reuses equal material descs")
	assert(builderLayer.Stats().TotalInstances == 2, "primitive3d builder emits layer instances")
	assert(builderLayer.Stats().TotalChunks == 2, "primitive3d builder preserves chunking")
	stream := voplay.NewDrawCtx()
	stream.UpsertPrimitive3DInstance(1, 2, 3, voplay.ModelID(4), voplay.Vec3{}, voplay.QuatIdentity(), voplay.Vec3{X: 1, Y: 1, Z: 1}, voplay.MaterialColor(voplay.Red), true)
	assert(len(stream.Bytes()) > 0 && stream.Bytes()[0] == 0x34, "primitive3d draw stream uses primitive upsert opcode")
	chunkStream := voplay.NewDrawCtx()
	chunkStream.ReplacePrimitive3DChunk(1, 2, 5, []voplay.Primitive3DInstanceDraw{voplay.Primitive3DInstanceDraw{ObjectID: 3, Model: voplay.ModelID(4), Rotation: voplay.QuatIdentity(), Scale: voplay.Vec3{X: 1, Y: 1, Z: 1}, Material: voplay.MaterialColor(voplay.Red), Visible: true}})
	assert(len(chunkStream.Bytes()) > 0 && chunkStream.Bytes()[0] == 0x38, "primitive3d draw stream uses chunk replace opcode")
	materialStream := voplay.NewDrawCtx()
	materialStream.UpsertPrimitive3DMaterials(1, 2, []voplay.Primitive3DMaterialDraw{voplay.Primitive3DMaterialDraw{ID: 7, Material: voplay.MaterialColor(voplay.Red)}})
	assert(len(materialStream.Bytes()) > 0 && materialStream.Bytes()[0] == 0x3A, "primitive3d draw stream uses material table opcode")
	refChunkStream := voplay.NewDrawCtx()
	refChunkStream.ReplacePrimitive3DChunkRefs(1, 2, 5, []voplay.Primitive3DInstanceRefDraw{voplay.Primitive3DInstanceRefDraw{ObjectID: 3, Model: voplay.ModelID(4), Rotation: voplay.QuatIdentity(), Scale: voplay.Vec3{X: 1, Y: 1, Z: 1}, MaterialID: 7, Visible: true}})
	assert(len(refChunkStream.Bytes()) > 0 && refChunkStream.Bytes()[0] == 0x39, "primitive3d draw stream uses compact chunk refs opcode")
	shapeStream := voplay.NewDrawCtx()
	shapeStream.UpsertPrimitive3DShapes(1, 2, []voplay.Primitive3DShapeDraw{voplay.Primitive3DShapeDraw{ID: 6, Model: voplay.ModelID(4)}})
	assert(len(shapeStream.Bytes()) > 0 && shapeStream.Bytes()[0] == 0x3B, "primitive3d draw stream uses shape table opcode")
	keyChunkStream := voplay.NewDrawCtx()
	keyChunkStream.ReplacePrimitive3DChunkKeys(1, 2, 5, []voplay.Primitive3DInstanceKeyDraw{voplay.Primitive3DInstanceKeyDraw{ObjectID: 3, ShapeID: 6, Rotation: voplay.QuatIdentity(), Scale: voplay.Vec3{X: 1, Y: 1, Z: 1}, MaterialID: 7, Visible: true}})
	assert(len(keyChunkStream.Bytes()) > 0 && keyChunkStream.Bytes()[0] == 0x3C, "primitive3d draw stream uses shape/material key chunk opcode")
	chunkVisibleStream := voplay.NewDrawCtx()
	chunkVisibleStream.SetPrimitive3DChunkVisible(1, 2, 5, false)
	assert(len(chunkVisibleStream.Bytes()) > 0 && chunkVisibleStream.Bytes()[0] == 0x3D, "primitive3d draw stream uses chunk visibility opcode")
	layer := primitive3d.NewLayer(primitive3d.LayerDesc{Kind: primitive3d.StaticLayer, Shapes: shapes, Materials: materials})
	id := layer.Add(primitive3d.Instance{Shape: rounded, Material: red, Position: voplay.Vec3{X: 1}})
	assert(id != 0, "primitive3d layer assigns object id")
	stats := layer.Stats()
	assert(stats.TotalInstances == 1, "primitive3d layer stats count instances")
	assert(stats.DirtyRanges == 1, "primitive3d layer marks add dirty")
	changes := layer.DrainChanges()
	assert(len(changes.Upserts) == 1 && len(changes.Removes) == 0, "primitive3d layer drains add as upsert")
	changes = layer.DrainChanges()
	assert(len(changes.Upserts) == 0 && len(changes.Removes) == 0, "primitive3d layer clean drain is empty")
	layer.Set(id, primitive3d.Instance{Shape: rounded, Material: red, Position: voplay.Vec3{X: 2}})
	changes = layer.DrainChanges()
	assert(len(changes.Upserts) == 1 && changes.Upserts[0].Position.X == 2, "primitive3d layer drains set as one upsert")
	layer.Remove(id)
	changes = layer.DrainChanges()
	assert(len(changes.Removes) == 1 && changes.Removes[0] == id, "primitive3d layer drains remove")
	chunkedLayer := primitive3d.NewLayer(primitive3d.LayerDesc{Kind: primitive3d.StaticLayer, Shapes: shapes, Materials: materials, Chunking: primitive3d.ChunkingDesc{CellSize: 10}})
	chunkedLayer.Add(primitive3d.Instance{Shape: rounded, Material: red, Position: voplay.Vec3{X: 0}})
	chunkedLayer.Add(primitive3d.Instance{Shape: rounded, Material: red, Position: voplay.Vec3{X: 20}})
	chunkedLayer.Build()
	assert(chunkedLayer.Stats().TotalChunks == 2, "primitive3d static layer builds grid chunks")
	assert(len(chunkedLayer.Chunks()) == 2, "primitive3d static layer exposes built chunks")
	changes = chunkedLayer.DrainChanges()
	assert(changes.All && len(changes.Upserts) == 2, "primitive3d build drains as whole-layer refresh")
	chunkedLayer.Invalidate()
	changes = chunkedLayer.DrainStaticChanges()
	assert(changes.All && len(changes.Upserts) == 0, "primitive3d static drain avoids whole-layer upsert allocation")
	sceneLayer := primitive3d.NewLayer(primitive3d.LayerDesc{Kind: primitive3d.StaticLayer, Shapes: shapes, Materials: materials})
	sceneLayer.Add(primitive3d.Instance{Shape: rounded, Material: red, Position: voplay.Vec3{X: 0}})
	sceneLayer.Add(primitive3d.Instance{Shape: rounded, Material: red, Position: voplay.Vec3{X: 1}})
	s := scene3d.New()
	handle := s.AddPrimitiveLayer(sceneLayer)
	assert(handle != 0, "scene3d primitive layer attach returns handle")
	d := voplay.NewDrawCtx()
	s.Draw(d)
	pstats := s.PrimitiveStats()
	assert(pstats.TotalInstances == 2, "scene3d primitive stats count layer instances")
	assert(pstats.ShapeMaterialGroups == 1, "scene3d primitive stats group shared shape/material")
	rstats := s.RenderStats()
	assert(rstats.UpsertedObjects == 2, "scene3d primitive first draw upserts layer instances")
	assert(rstats.BatchEligibleObjects == 2, "scene3d primitive instances are batch eligible")
	assert(rstats.BatchGroups == 1, "scene3d primitive shared material produces one batch group")
	d = voplay.NewDrawCtx()
	s.Draw(d)
	rstats = s.RenderStats()
	assert(rstats.UpsertedObjects == 0, "scene3d primitive clean second draw avoids upserts")
	assert(s.PrimitiveStats().DirtyRanges == 0, "scene3d primitive clean second draw has no dirty ranges")
	s.RemovePrimitiveLayer(handle)
	s.Close()
	culledLayer := primitive3d.NewLayer(primitive3d.LayerDesc{Kind: primitive3d.StaticLayer, Shapes: shapes, Materials: materials, Chunking: primitive3d.ChunkingDesc{CellSize: 10}})
	culledLayer.Add(primitive3d.Instance{Shape: rounded, Material: red, Position: voplay.Vec3{Z: -5}})
	culledLayer.Add(primitive3d.Instance{Shape: rounded, Material: red, Position: voplay.Vec3{Z: -2000}})
	culledLayer.Build()
	s = scene3d.New()
	s.Camera.Position = voplay.Vec3{X: 0, Y: 2, Z: 10}
	s.Camera.Target = voplay.Vec3{X: 0, Y: 2, Z: 0}
	s.Camera.Far = 100
	s.AddPrimitiveLayer(culledLayer)
	d = voplay.NewDrawCtx()
	s.Draw(d)
	pstats = s.PrimitiveStats()
	assert(pstats.TotalChunks == 2, "scene3d primitive stats keep total chunks")
	assert(pstats.VisibleChunks == 2, "scene3d primitive stats report uploaded chunks before Rust culling")
	assert(pstats.VisibleInstances == 2, "scene3d primitive stats report retained instances before Rust culling")
	assert(s.RenderStats().UpsertedObjects == 2, "scene3d primitive first draw uploads content chunks")
	s.Camera.Target = voplay.Vec3{X: 80, Y: 2, Z: 0}
	d = voplay.NewDrawCtx()
	s.Draw(d)
	assert(s.RenderStats().UpsertedObjects == 0, "scene3d primitive camera move emits no visibility patch")
	s.Close()
	stress := primitive3d.NewStressFixture(primitive3d.StressConfig{Count: 256, ShapeVariants: 4, MaterialVariants: 8, ChunkCellSize: 16})
	s = scene3d.New()
	s.Camera.Position = stress.Bounds.Center().Add(voplay.Vec3{Y: 80, Z: 90})
	s.Camera.Target = stress.Bounds.Center()
	s.Camera.Fov = 105
	s.Camera.Far = 500
	s.AddPrimitiveLayer(stress.Layer)
	first := voplay.NewDrawCtx()
	s.Draw(first)
	second := voplay.NewDrawCtx()
	s.Draw(second)
	assert(s.RenderStats().UpsertedObjects == 0, "scene3d primitive stress steady frame avoids upserts")
	assert(len(second.Bytes()) < len(first.Bytes()) / 10, "scene3d primitive stress steady frame is compact")
	s.Close()
}

func testScene3DRenderPerformanceContract() {
	ab := &testAnimationBackend{}
	prevBackend := scene3d.SetAnimationBackend(ab)
	defer scene3d.SetAnimationBackend(prevBackend)
	s := scene3d.New()
	for i := 0; i < 1000; i++ {
		x := float64(i % 50)
		z := -float64(i / 50)
		s.Spawn(scene3d.EntityDesc{Position: voplay.Vec3{X: x, Z: z}, Model: voplay.ModelID(77), StaticRenderable: true})
	}
	d := voplay.NewDrawCtx()
	s.Draw(d)
	stats := s.RenderStats()
	assert(stats.ModelEntities == 1000, "scene3d perf stats model count")
	assert(stats.BatchEligibleObjects == 1000, "scene3d perf stats batch eligible count")
	assert(stats.BatchGroups == 1, "scene3d perf stats shared model batch group")
	assert(stats.UpsertedObjects == 1000, "scene3d perf first retained draw upserts all objects")
	assert(stats.FlushCpuMs >= 0, "scene3d perf records retained flush cpu timing")
	assert(stats.FrameCpuMs >= 0, "scene3d perf records frame cpu timing")
	d2 := voplay.NewDrawCtx()
	s.Draw(d2)
	stats = s.RenderStats()
	assert(stats.UpsertedObjects == 0, "scene3d perf retained second draw avoids full scene serialization")
	assert(stats.FlushCpuMs >= 0, "scene3d perf second draw records flush cpu timing")
	assert(stats.FrameCpuMs >= 0, "scene3d perf second draw records frame cpu timing")
	s.Close()
	s = scene3d.New()
	s.Camera.Position = voplay.Vec3{X: 0, Y: 2, Z: 10}
	s.Camera.Target = voplay.Vec3{X: 0, Y: 2, Z: 0}
	s.Spawn(scene3d.EntityDesc{Position: voplay.Vec3{Z: -5}, Model: voplay.ModelID(78), StaticRenderable: true, CullDistance: 50, FrustumCull: true})
	s.Spawn(scene3d.EntityDesc{Position: voplay.Vec3{Z: 200}, Model: voplay.ModelID(78), StaticRenderable: true, CullDistance: 50, FrustumCull: true})
	d = voplay.NewDrawCtx()
	s.Draw(d)
	stats = s.RenderStats()
	assert(stats.ModelEntities == 2, "scene3d perf culling model count")
	assert(stats.VisibleEntities == 1, "scene3d perf culling visible count")
	assert(stats.CulledEntities == 1, "scene3d perf culling culled count")
	assert(stats.BatchEligibleObjects == 1, "scene3d perf culling batch eligible only visible")
	s.Close()
}

func testScene3DOwnedModelLifecycle() {
	freed := &intList{}
	mb := &testFreeModelBackend{freed: freed}
	mb.prev = voplay.SetModelBackend(mb)
	defer voplay.SetModelBackend(mb.prev)
	s := scene3d.New()
	eOwned := s.Spawn(scene3d.EntityDesc{OwnedModel: voplay.ModelID(101)})
	assert(eOwned.Model == voplay.ModelID(101), "scene3d owned model becomes entity model")
	s.Destroy(eOwned)
	assert(len(freed.items) == 1 && freed.items[0] == 101, "scene3d destroy frees owned model")
	eBorrowed := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(102)})
	s.Destroy(eBorrowed)
	assert(len(freed.items) == 1, "scene3d destroy does not free borrowed model")
	s.Spawn(scene3d.EntityDesc{OwnedModel: voplay.ModelID(103)})
	s.Clear()
	assert(len(freed.items) == 2 && freed.items[1] == 103, "scene3d clear frees owned model")
	s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(104), OwnedModel: voplay.ModelID(104)})
	s.Close()
	assert(len(freed.items) == 3 && freed.items[2] == 104, "scene3d close frees owned model when model matches owned model")
}

func testScene3DColliderWithOffset() {
	c := scene3d.Box(2, 3, 4)
	assert(c.Kind() == scene3d.ColliderBox, "scene3d collider kind")
	args := c.Args()
	assertFloatNear(args[0], 2, 0.000001, "scene3d box arg x")
	assertFloatNear(args[1], 3, 0.000001, "scene3d box arg y")
	assertFloatNear(args[2], 4, 0.000001, "scene3d box arg z")
	assertVec3Near(c.Offset(), voplay.Vec3{}, 0.000001, "scene3d box default offset")
	shifted := c.WithOffset(voplay.Vec3{X: 1, Y: 2, Z: 3})
	assertVec3Near(c.Offset(), voplay.Vec3{}, 0.000001, "scene3d box with offset returns copy")
	assertVec3Near(shifted.Offset(), voplay.Vec3{X: 1, Y: 2, Z: 3}, 0.000001, "scene3d box with offset value")
	sphere := scene3d.Sphere(5).WithOffset(voplay.Vec3{Y: -1})
	assert(sphere.Kind() == scene3d.ColliderSphere, "scene3d sphere collider kind")
	args = sphere.Args()
	assertFloatNear(args[0], 5, 0.000001, "scene3d sphere arg radius")
	assertVec3Near(sphere.Offset(), voplay.Vec3{Y: -1}, 0.000001, "scene3d sphere with offset value")
}

func testScene3DEntityHasSkeleton() {
	ab := &testAnimationBackend{}
	prevBackend := scene3d.SetAnimationBackend(ab)
	defer scene3d.SetAnimationBackend(prevBackend)
	s := scene3d.New()
	animated := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(901), Tag: "animated"})
	plain := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(902), Tag: "plain"})
	marker := s.Spawn(scene3d.EntityDesc{Tag: "marker"})
	assert(animated.HasSkeleton(), "scene3d animated entity reports skeleton")
	assert(!plain.HasSkeleton(), "scene3d plain entity reports no skeleton")
	assert(!marker.HasSkeleton(), "scene3d entity without model reports no skeleton")
	assert(ab.modelInfoCalls == 2, "scene3d HasSkeleton queries modeled entities once")
	assert(animated.HasSkeleton(), "scene3d animated entity cached skeleton result")
	assert(!plain.HasSkeleton(), "scene3d plain entity cached skeleton result")
	assert(ab.modelInfoCalls == 2, "scene3d HasSkeleton reuses cached model info")
	s.Close()
}

func testScene3DPickZeroDirection() {
	scene3DPickTestBounds = map[int]voplay.AABB{1: {Min: voplay.Vec3{X: -1, Y: -1, Z: -1}, Max: voplay.Vec3{X: 1, Y: 1, Z: 1}}}
	scene3DPickTestBoundsPresent = map[int]bool{1: true}
	scene3DPickTestBoundsCalls = 0
	prevBackend := voplay.SetModelBackend(&testPickModelBackend{})
	defer func() {
		voplay.SetModelBackend(prevBackend)
		scene3DPickTestBounds = nil
		scene3DPickTestBoundsPresent = nil
		scene3DPickTestBoundsCalls = 0
	}()
	s := scene3d.New()
	s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(1), Tag: "pickable"})
	hit := s.PickRay(voplay.Vec3{}, voplay.Vec3{}, 10)
	assert(hit == nil, "scene3d zero direction pick ray returns nil")
	all := s.PickAllRay(voplay.Vec3{}, voplay.Vec3{}, 10)
	assert(len(all) == 0, "scene3d zero direction pick all ray returns empty slice")
	assert(scene3DPickTestBoundsCalls == 0, "scene3d zero direction pick skips bounds queries")
	s.Close()
}

func testScene2DPhysicsBackend() {
	prev := scene2d.SetPhysicsBackend(nil)
	assert(prev != nil, "scene2d default physics backend is not nil")
	scene2d.SetPhysicsBackend(prev)
}

