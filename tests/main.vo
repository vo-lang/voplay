package main

import "github.com/vo-lang/voplay"
import "github.com/vo-lang/voplay/scene2d"

func assert(cond bool, msg string) {
	if !cond {
		panic("FAIL: " + msg)
	}
}

type eventLog struct {
	items []string
}

type assetRuntimeStats struct {
	nextTextureID int
	nextFontID    int
	nextModelID   int
	nextAudioID   int
	textureLoads  int
	textureFrees  int
	fontLoads     int
	fontFrees     int
	modelLoads    int
	modelFrees    int
	audioLoads    int
	audioFrees    int
	fileLoads     int
}

type testState struct {
	name             string
	events           *eventLog
	fixedUpdateCount int
	updateCount      int
	drawCount        int
	resizeCount      int
	blockUpdateBelow bool
	blockDrawBelow   bool
}

func (s *testState) Enter(g *voplay.GameCtx) {
	s.events.items = append(s.events.items, s.name+":enter")
}

func (s *testState) Exit(g *voplay.GameCtx) {
	s.events.items = append(s.events.items, s.name+":exit")
}

func (s *testState) Pause(g *voplay.GameCtx) {
	s.events.items = append(s.events.items, s.name+":pause")
}

func (s *testState) Resume(g *voplay.GameCtx) {
	s.events.items = append(s.events.items, s.name+":resume")
}

func (s *testState) FixedUpdate(g *voplay.GameCtx, dt float64) {
	s.fixedUpdateCount++
	s.events.items = append(s.events.items, s.name+":fixed")
}

func (s *testState) Update(g *voplay.GameCtx, dt float64) {
	s.updateCount++
	s.events.items = append(s.events.items, s.name+":update")
}

func (s *testState) Draw(g *voplay.GameCtx) {
	s.drawCount++
	s.events.items = append(s.events.items, s.name+":draw")
}

func (s *testState) OnResize(g *voplay.GameCtx, w int, h int) {
	s.resizeCount++
	s.events.items = append(s.events.items, s.name+":resize")
}

func (s *testState) BlocksUpdateBelow() bool {
	return s.blockUpdateBelow
}

func (s *testState) BlocksDrawBelow() bool {
	return s.blockDrawBelow
}

func newTestCtx() *voplay.GameCtx {
	ctx := &voplay.GameCtx{
		Input:  voplay.NewInputState(),
		Draw:   voplay.NewDrawCtx(),
		Width:  640,
		Height: 480,
		FixedStep: 1.0 / 60.0,
	}
	ctx.Actions = voplay.NewActionMap(ctx.Input)
	ctx.Assets = voplay.NewAssets()
	ctx.States = voplay.NewStateStack(ctx)
	return ctx
}

func newMockAssetLoaders(stats *assetRuntimeStats) voplay.AssetLoaders {
	return voplay.AssetLoaders{
		Texture: voplay.AssetLoader{
			LoadFile: func(path string) (int, error) {
				stats.textureLoads++
				stats.fileLoads++
				stats.nextTextureID++
				return stats.nextTextureID, nil
			},
			LoadBytes: func(data []byte) (int, error) {
				stats.textureLoads++
				stats.nextTextureID++
				return stats.nextTextureID, nil
			},
			Free: func(id int) {
				stats.textureFrees++
			},
		},
		Font: voplay.AssetLoader{
			LoadFile: func(path string) (int, error) {
				stats.fontLoads++
				stats.fileLoads++
				stats.nextFontID++
				return stats.nextFontID, nil
			},
			LoadBytes: func(data []byte) (int, error) {
				stats.fontLoads++
				stats.nextFontID++
				return stats.nextFontID, nil
			},
			Free: func(id int) {
				stats.fontFrees++
			},
		},
		Model: voplay.AssetLoader{
			LoadFile: func(path string) (int, error) {
				stats.modelLoads++
				stats.fileLoads++
				stats.nextModelID++
				return stats.nextModelID, nil
			},
			LoadBytes: func(data []byte) (int, error) {
				stats.modelLoads++
				stats.nextModelID++
				return stats.nextModelID, nil
			},
			Free: func(id int) {
				stats.modelFrees++
			},
		},
		Audio: voplay.AssetLoader{
			LoadFile: func(path string) (int, error) {
				stats.audioLoads++
				stats.fileLoads++
				stats.nextAudioID++
				return stats.nextAudioID, nil
			},
			LoadBytes: func(data []byte) (int, error) {
				stats.audioLoads++
				stats.nextAudioID++
				return stats.nextAudioID, nil
			},
			Free: func(id int) {
				stats.audioFrees++
			},
		},
	}
}

func assertEvents(events []string, want []string, label string) {
	assert(len(events) == len(want), label+": len")
	for i := range want {
		assert(events[i] == want[i], label+": event")
	}
}

func assertFloatNear(got, want, tol float64, label string) {
	diff := got - want
	if diff < 0 {
		diff = -diff
	}
	assert(diff <= tol, label)
}

func assertFloatFar(got, want, tol float64, label string) {
	diff := got - want
	if diff < 0 {
		diff = -diff
	}
	assert(diff > tol, label)
}

func capturePanic(fn func()) (any, bool) {
	var recovered any
	var didPanic bool
	func() {
		defer func() {
			recovered = recover()
			didPanic = recovered != nil
		}()
		fn()
	}()
	return recovered, didPanic
}

func testLifecycle() {
	ctx := newTestCtx()
	log := &eventLog{}
	a := &testState{name: "a", events: log, blockUpdateBelow: true, blockDrawBelow: true}
	b := &testState{name: "b", events: log, blockUpdateBelow: true, blockDrawBelow: false}
	c := &testState{name: "c", events: log, blockUpdateBelow: true, blockDrawBelow: true}

	ctx.States.Push(a)
	assert(ctx.States.Len() == 1, "push a len")
	assert(ctx.States.Top() == a, "push a top")
	assertEvents(log.items, []string{"a:enter"}, "push a events")

	ctx.States.Push(b)
	assert(ctx.States.Len() == 2, "push b len")
	assert(ctx.States.Top() == b, "push b top")
	assertEvents(log.items, []string{"a:enter", "a:pause", "b:enter"}, "push b events")

	popped := ctx.States.Pop()
	assert(popped == b, "pop returns b")
	assert(ctx.States.Len() == 1, "pop len")
	assert(ctx.States.Top() == a, "pop top")
	assertEvents(log.items, []string{"a:enter", "a:pause", "b:enter", "b:exit", "a:resume"}, "pop events")

	ctx.States.Replace(c)
	assert(ctx.States.Len() == 1, "replace len")
	assert(ctx.States.Top() == c, "replace top")
	assertEvents(log.items, []string{"a:enter", "a:pause", "b:enter", "b:exit", "a:resume", "a:exit", "c:enter"}, "replace events")
}

func testUpdateAndDrawBarriers() {
	ctx := newTestCtx()
	log := &eventLog{}
	base := &testState{name: "base", events: log, blockUpdateBelow: true, blockDrawBelow: true}
	overlay := &testState{name: "overlay", events: log, blockUpdateBelow: false, blockDrawBelow: false}
	pause := &testState{name: "pause", events: log, blockUpdateBelow: true, blockDrawBelow: false}

	ctx.States.Push(base)
	ctx.States.Push(overlay)
	assert(len(log.items) == 3, "overlay setup events")
	log.items = log.items[:0]

	ctx.States.Update(0.016)
	assertEvents(log.items, []string{"base:update", "overlay:update"}, "overlay update propagation")
	assert(base.updateCount == 1, "base updated once")
	assert(overlay.updateCount == 1, "overlay updated once")
	assert(pause.updateCount == 0, "pause update untouched")
	assert(base.fixedUpdateCount == 0, "base fixed update untouched")

	log.items = log.items[:0]
	ctx.States.FixedUpdate(0.016)
	assertEvents(log.items, []string{"base:fixed", "overlay:fixed"}, "overlay fixed update propagation")
	assert(base.fixedUpdateCount == 1, "base fixed updated once")
	assert(overlay.fixedUpdateCount == 1, "overlay fixed updated once")
	assert(pause.fixedUpdateCount == 0, "pause fixed update untouched")

	log.items = log.items[:0]
	ctx.States.Draw()
	assertEvents(log.items, []string{"base:draw", "overlay:draw"}, "overlay draw propagation")
	assert(base.drawCount == 1, "base drawn once")
	assert(overlay.drawCount == 1, "overlay drawn once")

	log.items = log.items[:0]
	ctx.States.Replace(pause)
	assertEvents(log.items, []string{"overlay:exit", "pause:enter"}, "replace overlay with pause")

	log.items = log.items[:0]
	ctx.States.Update(0.016)
	assertEvents(log.items, []string{"pause:update"}, "pause blocks update below")
	assert(base.updateCount == 1, "base not updated behind pause")
	assert(pause.updateCount == 1, "pause updated once")
	assert(base.fixedUpdateCount == 1, "base fixed update count preserved")

	log.items = log.items[:0]
	ctx.States.FixedUpdate(0.016)
	assertEvents(log.items, []string{"pause:fixed"}, "pause blocks fixed update below")
	assert(base.fixedUpdateCount == 1, "base fixed update blocked behind pause")
	assert(pause.fixedUpdateCount == 1, "pause fixed updated once")

	log.items = log.items[:0]
	ctx.States.Draw()
	assertEvents(log.items, []string{"base:draw", "pause:draw"}, "pause allows draw below")
	assert(base.drawCount == 2, "base drawn behind pause")
	assert(pause.drawCount == 1, "pause drawn once")
}

func testAdvanceFixedTimestep() {
	ctx := newTestCtx()
	ctx.FixedStep = 0.02
	log := &eventLog{}
	base := &testState{name: "base", events: log, blockUpdateBelow: true, blockDrawBelow: true}
	overlay := &testState{name: "overlay", events: log, blockUpdateBelow: false, blockDrawBelow: false}

	ctx.States.Push(base)
	ctx.States.Push(overlay)
	log.items = log.items[:0]

	ctx.Advance(0.05)
	assertEvents(log.items, []string{
		"base:fixed",
		"overlay:fixed",
		"base:fixed",
		"overlay:fixed",
		"base:update",
		"overlay:update",
	}, "advance fixed timestep order")
	assert(base.fixedUpdateCount == 2, "base fixed updated twice")
	assert(overlay.fixedUpdateCount == 2, "overlay fixed updated twice")
	assert(base.updateCount == 1, "base updated once after fixed steps")
	assert(overlay.updateCount == 1, "overlay updated once after fixed steps")
	assertFloatNear(ctx.Alpha, 0.5, 0.000001, "advance alpha")
}

func testActionMap() {
	ctx := newTestCtx()
	actions := ctx.Actions
	actions.Bind("left", voplay.KeyBinding("ArrowLeft"), voplay.KeyBinding("a"))
	actions.Bind("fire", voplay.PointerBinding(0))
	actions.Bind("right", voplay.KeyBinding("ArrowRight"), voplay.KeyBinding("d"))

	ctx.Input.KeyDown("a")
	assert(actions.IsDown("left"), "left action down from alternate key")
	assert(actions.IsPressed("left"), "left action pressed on first frame")
	assert(actions.Axis("left", "right") == -1, "axis negative")

	ctx.Input.EndFrame()
	assert(actions.IsDown("left"), "left action remains down after frame end")
	assert(!actions.IsPressed("left"), "left pressed clears after frame end")

	ctx.Input.KeyDown("ArrowRight")
	assert(actions.Axis("left", "right") == 0, "axis cancels when both sides held")
	ctx.Input.KeyUp("a")
	ctx.Input.KeyUp("ArrowRight")
	assert(actions.IsReleased("left"), "left action released")
	assert(actions.IsReleased("right"), "right action released")
	assert(actions.Axis("left", "right") == 0, "axis neutral after release")

	ctx.Input.EndFrame()
	ctx.Input.PointerDown(20, 30, 0)
	assert(actions.IsDown("fire"), "pointer binding down")
	assert(actions.IsPressed("fire"), "pointer binding pressed")
	ctx.Input.PointerUp(20, 30, 0)
	assert(actions.IsReleased("fire"), "pointer binding released")

	actions.Rebind("left", voplay.KeyBinding("j"))
	ctx.Input.EndFrame()
	ctx.Input.KeyDown("j")
	assert(actions.IsDown("left"), "rebind replaces action binding")
	ctx.Input.KeyUp("j")
	actions.Unbind("right")
	assert(actions.IsReleased("left"), "rebound key released")
}

func testCollisionFilterValidation() {
	assert(voplay.CollisionLayerDefault == 1, "collision default layer")
	assert(voplay.CollisionMaskAll == 0xFFFF, "collision all mask")
	voplay.ValidateCollisionFilter(0, 0)
	voplay.ValidateCollisionFilter(voplay.CollisionMaskAll, voplay.CollisionMaskAll)
	_, didPanic := capturePanic(func() {
		voplay.ValidateCollisionFilter(-1, 1)
	})
	assert(didPanic, "negative collision layer panics")
	_, didPanic = capturePanic(func() {
		voplay.ValidateCollisionFilter(1, 0x10000)
	})
	assert(didPanic, "overflow collision mask panics")
}

func testAssets() {
	stats := &assetRuntimeStats{}
	assets := voplay.NewAssetsWithLoaders(newMockAssetLoaders(stats))

	// Path-based loading with deduplication
	assets.BeginGroup("global")
	tex1, err := assets.Texture("ui.png")
	assert(err == nil, "assets texture load")
	tex2, err := assets.Texture("ui.png")
	assert(err == nil, "assets texture dedupe load")
	assert(tex1 == tex2, "assets texture dedupe id")
	assert(stats.textureLoads == 1, "assets texture loaded once in same group")
	assert(stats.fileLoads == 1, "assets texture loaded via file")
	assets.EndGroup()

	// Cross-group sharing and bytes-based loading
	assets.BeginGroup("level")
	tex3, err := assets.Texture("ui.png")
	assert(err == nil, "assets texture cross-group load")
	assert(tex3 == tex1, "assets texture shared across groups")
	font1, err := assets.FontBytes("hud.font", []byte{1, 2, 3})
	assert(err == nil, "assets font bytes load")
	audio1, err := assets.AudioBytes("click", []byte{4, 5, 6})
	assert(err == nil, "assets audio bytes load")
	assert(font1 != 0, "assets font id")
	assert(audio1 != 0, "assets audio id")
	assets.EndGroup()

	// Releasing a group frees assets not shared with other groups
	assets.ReleaseGroup("level")
	assert(stats.textureFrees == 0, "shared texture not freed with remaining owner")
	assert(stats.fontFrees == 1, "font freed with owning group")
	assert(stats.audioFrees == 1, "audio freed with owning group")

	// Source mismatch: loading same key via path then bytes panics
	_, didPanic := capturePanic(func() {
		assets.BeginGroup("mismatch")
		_, _ = assets.Texture("conflict.png")
		_, _ = assets.TextureBytes("conflict.png", []byte{9, 9})
	})
	assert(didPanic, "assets source mismatch panics")
	assets.EndGroup()

	assets.ReleaseGroup("global")
	assert(stats.textureFrees == 1, "shared texture freed after last owner releases")

	assets.BeginGroup("transient")
	_, err = assets.ModelBytes("ship", []byte{7, 8})
	assert(err == nil, "assets model bytes load")
	assets.EndGroup()
	assets.ReleaseAll()
	assert(stats.modelFrees == 1, "release all frees remaining model")
}

func testScene2DCamera() {
	cam := scene2d.Camera{Zoom: 1.0}
	cam.FollowWithDeadzone(20, 3, 10, 10, 1.0)
	assertFloatNear(cam.X, 15, 0.000001, "camera deadzone follow x")
	assertFloatNear(cam.Y, 0, 0.000001, "camera deadzone follow y")

	cam.Bounds = voplay.Rect{X: 0, Y: 0, W: 100, H: 80}
	cam.X = 95
	cam.Y = 70
	vr := cam.ViewRect(40, 20)
	centerX, centerY := vr.Center()
	assertFloatNear(centerX, 80, 0.000001, "camera bounds clamp x")
	assertFloatNear(centerY, 70, 0.000001, "camera bounds clamp y")

	cam.Bounds = voplay.Rect{}
	cam.X = 10
	cam.Y = 20
	cam.Shake(8, 1.0)
	cam.Update(0.25)
	vr = cam.ViewRect(40, 20)
	centerX, centerY = vr.Center()
	assertFloatFar(centerX, 10, 0.000001, "camera shake offsets x")
	assertFloatFar(centerY, 20, 0.000001, "camera shake offsets y")
	cam.Update(1.0)
	vr = cam.ViewRect(40, 20)
	centerX, centerY = vr.Center()
	assertFloatNear(centerX, 10, 0.000001, "camera shake settles x")
	assertFloatNear(centerY, 20, 0.000001, "camera shake settles y")
}

func testResizeAndReset() {
	ctx := newTestCtx()
	log := &eventLog{}
	a := &testState{name: "a", events: log, blockUpdateBelow: true, blockDrawBelow: true}
	b := &testState{name: "b", events: log, blockUpdateBelow: false, blockDrawBelow: false}
	c := &testState{name: "c", events: log, blockUpdateBelow: true, blockDrawBelow: true}

	ctx.States.Push(a)
	ctx.States.Push(b)
	log.items = log.items[:0]

	ctx.States.Resize(800, 600)
	assertEvents(log.items, []string{"a:resize", "b:resize"}, "resize dispatch")
	assert(a.resizeCount == 1, "a resize count")
	assert(b.resizeCount == 1, "b resize count")

	log.items = log.items[:0]
	ctx.States.Reset(c)
	assert(ctx.States.Len() == 1, "reset len")
	assert(ctx.States.Top() == c, "reset top")
	assertEvents(log.items, []string{"b:exit", "a:exit", "c:enter"}, "reset events")
}

func testScheduler() {
	s := voplay.NewScheduler()
	assert(s.Len() == 0, "scheduler empty on creation")

	fired := 0
	h := s.After(0.1, func() { fired++ })
	assert(s.Len() == 1, "scheduler len after After")

	s.Update(0.05)
	assert(fired == 0, "not fired before delay")
	s.Update(0.05)
	assert(fired == 1, "fired exactly at delay")
	assert(s.Len() == 0, "one-shot removed after fire")

	s.Update(0.1)
	assert(fired == 1, "one-shot does not re-fire")

	repeatCount := 0
	s.Every(0.1, func() { repeatCount++ })
	s.Update(0.25)
	assert(repeatCount == 2, "every fires twice in 0.25s with 0.1s interval")
	s.Update(0.1)
	assert(repeatCount == 3, "every fires third time")
	assert(s.Len() == 1, "repeating entry stays active")

	cancelCount := 0
	ch := s.After(0.2, func() { cancelCount++ })
	s.Cancel(ch)
	s.Update(0.3)
	assert(cancelCount == 0, "cancelled one-shot does not fire")

	s.Clear()
	assert(s.Len() == 0, "clear empties scheduler")

	deferredFired := 0
	s.After(0.0, func() {
		s.After(0.0, func() { deferredFired++ })
	})
	s.Update(0.0)
	assert(deferredFired == 0, "entry added in callback deferred to next update")
	s.Update(0.0)
	assert(deferredFired == 1, "deferred entry fires on next update")

	cancelDuringCount := 0
	var hCancel voplay.SchedulerHandle
	hCancel = s.Every(0.05, func() {
		cancelDuringCount++
		s.Cancel(hCancel)
	})
	s.Update(0.1)
	assert(cancelDuringCount == 1, "self-cancelling every fires exactly once")
	s.Update(0.1)
	assert(cancelDuringCount == 1, "self-cancelled every does not fire again")

	_, didPanic := capturePanic(func() { s.After(-1, func() {}) })
	assert(didPanic, "After negative delay panics")
	_, didPanic = capturePanic(func() { s.Every(0, func() {}) })
	assert(didPanic, "Every zero interval panics")
	_, didPanic = capturePanic(func() { s.After(0, nil) })
	assert(didPanic, "After nil fn panics")
}

func testTween() {
	tw := voplay.NewTween(0, 100, 1.0, voplay.EaseLinear)
	assertFloatNear(tw.Value(), 0, 0.000001, "tween initial value")
	assert(!tw.Done(), "tween not done initially")

	tw.Update(0.5)
	assertFloatNear(tw.Value(), 50, 0.000001, "tween midpoint linear")
	assertFloatNear(tw.Progress(), 0.5, 0.000001, "tween progress midpoint")

	tw.Update(0.5)
	assertFloatNear(tw.Value(), 100, 0.000001, "tween at end")
	assert(tw.Done(), "tween done after full duration")

	tw.Update(0.5)
	assertFloatNear(tw.Value(), 100, 0.000001, "tween stays at end after done")

	tw.Reset()
	assert(!tw.Done(), "tween not done after reset")
	assertFloatNear(tw.Value(), 0, 0.000001, "tween resets to start")

	doneFired := 0
	updateValues := []float64{}
	tw2 := voplay.NewTween(10, 20, 0.5, voplay.EaseLinear).
		WithOnUpdate(func(v float64) { updateValues = append(updateValues, v) }).
		WithOnDone(func() { doneFired++ })
	tw2.Update(0.5)
	assert(doneFired == 1, "OnDone fired on completion")
	assert(len(updateValues) == 1, "OnUpdate called once")
	assertFloatNear(updateValues[0], 20, 0.000001, "OnUpdate receives final value")

	twLoop := voplay.NewTween(0, 1, 0.5, voplay.EaseLinear).WithLoop()
	twLoop.Update(0.75)
	assert(!twLoop.Done(), "looping tween never done")
	assertFloatNear(twLoop.Progress(), 0.5, 0.001, "loop tween at midpoint of second cycle after 0.75s")

	twPP := voplay.NewTween(0, 100, 0.5, voplay.EaseLinear).WithPingPong()
	twPP.Update(0.5)
	assertFloatNear(twPP.Value(), 100, 0.000001, "pingpong at endpoint")
	twPP.Update(0.25)
	assertFloatNear(twPP.Value(), 50, 0.000001, "pingpong reversed at midpoint")
	twPP.Update(0.25)
	assertFloatNear(twPP.Value(), 0, 0.000001, "pingpong back to start")
	assert(!twPP.Done(), "pingpong never done")

	twEase := voplay.NewTween(0, 1, 1.0, voplay.EaseInQuad)
	twEase.Update(0.5)
	assertFloatNear(twEase.Value(), 0.25, 0.000001, "EaseInQuad at 0.5 = 0.25")

	twOut := voplay.NewTween(0, 1, 1.0, voplay.EaseOutQuad)
	twOut.Update(0.5)
	assertFloatNear(twOut.Value(), 0.75, 0.000001, "EaseOutQuad at 0.5 = 0.75")

	assertFloatNear(voplay.EaseOutBounce(1.0), 1.0, 0.000001, "EaseOutBounce at 1.0")
	assertFloatNear(voplay.EaseOutBounce(0.0), 0.0, 0.000001, "EaseOutBounce at 0.0")
	assertFloatNear(voplay.EaseInBounce(0.0), 0.0, 0.000001, "EaseInBounce at 0.0")
	assertFloatNear(voplay.EaseInBounce(1.0), 1.0, 0.000001, "EaseInBounce at 1.0")

	assertFloatNear(voplay.EaseInOutBack(0.0), 0.0, 0.000001, "EaseInOutBack at 0.0")
	assertFloatNear(voplay.EaseInOutBack(0.5), 0.5, 0.000001, "EaseInOutBack at 0.5 = 0.5")
	assertFloatNear(voplay.EaseInOutBack(1.0), 1.0, 0.000001, "EaseInOutBack at 1.0")

	assertFloatNear(voplay.EaseInElastic(0.0), 0.0, 0.000001, "EaseInElastic at 0.0")
	assertFloatNear(voplay.EaseInElastic(1.0), 1.0, 0.000001, "EaseInElastic at 1.0")
	assertFloatNear(voplay.EaseOutElastic(0.0), 0.0, 0.000001, "EaseOutElastic at 0.0")
	assertFloatNear(voplay.EaseOutElastic(1.0), 1.0, 0.000001, "EaseOutElastic at 1.0")
	assertFloatNear(voplay.EaseInOutElastic(0.0), 0.0, 0.000001, "EaseInOutElastic at 0.0")
	assertFloatNear(voplay.EaseInOutElastic(0.5), 0.5, 0.000001, "EaseInOutElastic at 0.5")
	assertFloatNear(voplay.EaseInOutElastic(1.0), 1.0, 0.000001, "EaseInOutElastic at 1.0")

	// WithOnUpdate(nil) and WithOnDone(nil) clear their callbacks.
	clearUpdateCount := 0
	clearDoneCount := 0
	twClear := voplay.NewTween(0, 1, 0.1, voplay.EaseLinear).
		WithOnUpdate(func(v float64) { clearUpdateCount++ }).
		WithOnDone(func() { clearDoneCount++ })
	twClear.WithOnUpdate(nil)
	twClear.WithOnDone(nil)
	twClear.Update(0.1)
	assert(clearUpdateCount == 0, "WithOnUpdate(nil) clears callback")
	assert(clearDoneCount == 0, "WithOnDone(nil) clears callback")

	_, didPanic := capturePanic(func() { voplay.NewTween(0, 1, 0, nil) })
	assert(didPanic, "NewTween zero duration panics")
	_, didPanic = capturePanic(func() { voplay.NewTween(0, 1, -1, nil) })
	assert(didPanic, "NewTween negative duration panics")
}

func testMath() {
	v := voplay.Vec2{X: 3, Y: -5}
	neg := v.Negate()
	assert(neg.X == -3, "Vec2.Negate X")
	assert(neg.Y == 5, "Vec2.Negate Y")

	v3 := voplay.Vec3{X: 1, Y: -2, Z: 3}
	neg3 := v3.Negate()
	assert(neg3.X == -1, "Vec3.Negate X")
	assert(neg3.Y == 2, "Vec3.Negate Y")
	assert(neg3.Z == -3, "Vec3.Negate Z")
}

func testTilemapExtra() {
	ts := &scene2d.TileSet{TileW: 32, TileH: 32, Columns: 4}
	tm := scene2d.NewTilemap(ts, 8, 8)

	// Positive coords: standard case.
	col, row := tm.WorldToTile(33, 97)
	assert(col == 1, "WorldToTile positive x")
	assert(row == 3, "WorldToTile positive y")

	// Exact boundary: wx = 32.0 should land in tile 1.
	col, row = tm.WorldToTile(32.0, 0)
	assert(col == 1, "WorldToTile exact boundary")

	// Negative coords: int() truncates toward zero giving wrong tile;
	// math.Floor must be used.
	col, row = tm.WorldToTile(-0.5, -0.5)
	assert(col == -1, "WorldToTile negative x maps to col -1")
	assert(row == -1, "WorldToTile negative y maps to row -1")

	col, row = tm.WorldToTile(-32.0, -32.0)
	assert(col == -1, "WorldToTile exactly -TileW")
	assert(row == -1, "WorldToTile exactly -TileH")

	col, row = tm.WorldToTile(-33.0, -33.0)
	assert(col == -2, "WorldToTile further negative x")
	assert(row == -2, "WorldToTile further negative y")
}

func testAnimController() {
	sheet := scene2d.NewSpriteSheet(voplay.TextureID(1), 16, 16, 4)
	clipIdle := &scene2d.AnimClip{
		Sheet:  sheet,
		Frames: []int{0, 1, 2, 3},
		FPS:    8,
		Loop:   true,
	}
	clipAttack := &scene2d.AnimClip{
		Sheet:  sheet,
		Frames: []int{4, 5, 6},
		FPS:    12,
		Loop:   false,
	}

	ac := scene2d.NewAnimController()
	assert(ac.CurrentClip() == "", "no clip initially")
	assert(!ac.Done(), "not done with no clip")

	ac.AddClip("idle", clipIdle)
	ac.AddClip("attack", clipAttack)

	ac.SetState("idle")
	assert(ac.CurrentClip() == "idle", "clip set to idle")
	assert(!ac.Done(), "idle loop not done")

	frameDur := 1.0 / 8.0
	ac.Update(frameDur * 2)
	x, y, w, h := ac.CurrentFrame()
	assert(w == 16, "frame width correct")
	assert(h == 16, "frame height correct")
	srcCol := int(x) / 16
	assert(srcCol == 2, "advanced to frame index 2 after 2 frame durations")
	_ = y

	ac.SetState("idle")
	assert(ac.CurrentClip() == "idle", "SetState no-op same clip")
	assert(srcCol == 2, "frame not reset on same-clip SetState")

	ac.SetState("attack")
	assert(ac.CurrentClip() == "attack", "transitioned to attack")
	assert(!ac.Done(), "attack not done immediately")

	attackFrameDur := 1.0 / 12.0
	ac.Update(attackFrameDur * 3)
	assert(ac.Done(), "attack done after all frames")

	ac.Update(attackFrameDur * 5)
	assert(ac.Done(), "attack stays done")
	x2, _, _, _ := ac.CurrentFrame()
	srcCol2 := int(x2) / 16
	assert(srcCol2 == 2, "attack stuck on last frame index (4+2=6 in sheet col 2)")

	ac.SetStateForce("attack")
	assert(!ac.Done(), "SetStateForce resets done")
	assert(ac.CurrentClip() == "attack", "SetStateForce set to attack")

	spr := &scene2d.Sprite{Tint: voplay.White}
	ac.ApplyToSprite(spr)
	assert(spr.Texture == voplay.TextureID(1), "ApplyToSprite sets texture")
	assert(spr.SrcW == 16, "ApplyToSprite sets SrcW")
	assert(spr.SrcH == 16, "ApplyToSprite sets SrcH")

	assert(ac.HasClip("idle"), "HasClip returns true for registered clip")
	assert(ac.HasClip("attack"), "HasClip returns true for attack")
	assert(!ac.HasClip("jump"), "HasClip returns false for unregistered clip")
	assert(!ac.HasClip(""), "HasClip returns false for empty name")

	onDoneFired := 0
	lastDoneClip := ""
	ac.WithOnDone(func() {
		onDoneFired++
		lastDoneClip = ac.CurrentClip()
	})
	ac.SetState("attack")
	ac.Update(attackFrameDur * 3)
	assert(onDoneFired == 1, "OnDone fires when non-looping clip ends")
	assert(lastDoneClip == "attack", "OnDone sees current clip as attack")

	ac.SetState("idle")
	ac.Update(1.0)
	assert(onDoneFired == 1, "OnDone not fired for looping clip")

	ac.WithOnDone(nil)
	ac.SetState("attack")
	ac.Update(attackFrameDur * 3)
	assert(onDoneFired == 1, "WithOnDone nil clears callback")

	_, didPanic := capturePanic(func() { ac.AddClip("idle", clipIdle) })
	assert(didPanic, "AddClip duplicate name panics")
	_, didPanic = capturePanic(func() { ac.SetState("unknown") })
	assert(didPanic, "SetState unknown clip panics")
	_, didPanic = capturePanic(func() { ac.ApplyToSprite(nil) })
	assert(didPanic, "ApplyToSprite nil panics")
}

func testScene2DFindByID() {
	s := scene2d.New()

	e1 := s.Spawn(scene2d.EntityDesc{
		Position: voplay.Vec2{10, 20},
		Size:     voplay.Vec2{8, 8},
		Tag:      "a",
	})
	e2 := s.Spawn(scene2d.EntityDesc{
		Position: voplay.Vec2{50, 60},
		Size:     voplay.Vec2{8, 8},
		Tag:      "b",
	})

	// FindByID returns the correct entity.
	found := s.FindByID(e1.ID())
	assert(found == e1, "FindByID returns e1")
	found = s.FindByID(e2.ID())
	assert(found == e2, "FindByID returns e2")

	// FindByID returns nil for unknown ID.
	assert(s.FindByID(9999) == nil, "FindByID unknown returns nil")

	// After Destroy, FindByID returns nil.
	s.Destroy(e1)
	assert(s.FindByID(e1.ID()) == nil, "FindByID after destroy returns nil")
	assert(s.FindByID(e2.ID()) == e2, "FindByID e2 still valid after e1 destroyed")

	s.Close()
}

func testScene2DSetActive() {
	s := scene2d.New()

	e := s.Spawn(scene2d.EntityDesc{
		Position: voplay.Vec2{10, 20},
		Size:     voplay.Vec2{16, 16},
		Tag:      "player",
	})

	// Entity is found in spatial query when active.
	result := s.FindInRect(voplay.Rect{X: 0, Y: 0, W: 100, H: 100})
	assert(len(result) == 1, "active entity found in rect")

	// Deactivate via SetActive — entity removed from spatial index.
	s.SetActive(e, false)
	assert(!e.Active, "SetActive false sets Active")
	result = s.FindInRect(voplay.Rect{X: 0, Y: 0, W: 100, H: 100})
	assert(len(result) == 0, "inactive entity not found in rect")

	// Move entity while inactive.
	e.SetLocalPosition(500, 500)

	// Reactivate via SetActive — spatial index updated to new position.
	s.SetActive(e, true)
	assert(e.Active, "SetActive true sets Active")

	// Old position: should NOT find it.
	result = s.FindInRect(voplay.Rect{X: 0, Y: 0, W: 50, H: 50})
	assert(len(result) == 0, "reactivated entity not at old position")

	// New position: should find it.
	result = s.FindInRect(voplay.Rect{X: 490, Y: 490, W: 30, H: 30})
	assert(len(result) == 1, "reactivated entity found at new position")

	// SetActive is idempotent.
	s.SetActive(e, true)
	result = s.FindInRect(voplay.Rect{X: 490, Y: 490, W: 30, H: 30})
	assert(len(result) == 1, "SetActive idempotent")

	s.Close()
}

func main() {
	testLifecycle()
	testUpdateAndDrawBarriers()
	testAdvanceFixedTimestep()
	testActionMap()
	testCollisionFilterValidation()
	testAssets()
	testScene2DCamera()
	testResizeAndReset()
	testScheduler()
	testTween()
	testMath()
	testTilemapExtra()
	testAnimController()
	testScene2DFindByID()
	testScene2DSetActive()
	println("ALL TESTS PASSED")
}
