func assert(cond bool, msg string) {
	if !cond {
		panic("FAIL: " + msg)
	}
}

type eventLog struct {
	items []string
}

type assetRuntimeStats struct {
	nextTextureID int
	nextFontID int
	nextModelID int
	nextAudioID int
	textureLoads int
	textureFrees int
	fontLoads int
	fontFrees int
	modelLoads int
	modelFrees int
	audioLoads int
	audioFrees int
	fileLoads int
}

type testState struct {
	name string
	events *eventLog
	fixedUpdateCount int
	updateCount int
	drawCount int
	resizeCount int
	blockUpdateBelow bool
	blockDrawBelow bool
}

var scene3DPickTestBounds map[int]voplay.AABB

var scene3DPickTestBoundsPresent map[int]bool

var scene3DPickTestBoundsCalls int

func scene3DPickModelBounds(id int) (voplay.AABB, bool) {
	scene3DPickTestBoundsCalls++
	if scene3DPickTestBoundsPresent[id] {
		return scene3DPickTestBounds[id], true
	}
	return voplay.AABB{}, false
}

func (s *testState) Enter(g *voplay.GameCtx) {
	s.events.items = append(s.events.items, s.name + ":enter")
}

func (s *testState) Exit(g *voplay.GameCtx) {
	s.events.items = append(s.events.items, s.name + ":exit")
}

func (s *testState) Pause(g *voplay.GameCtx) {
	s.events.items = append(s.events.items, s.name + ":pause")
}

func (s *testState) Resume(g *voplay.GameCtx) {
	s.events.items = append(s.events.items, s.name + ":resume")
}

func (s *testState) FixedUpdate(g *voplay.GameCtx, dt float64) {
	s.fixedUpdateCount++
	s.events.items = append(s.events.items, s.name + ":fixed")
}

func (s *testState) Update(g *voplay.GameCtx, dt float64) {
	s.updateCount++
	s.events.items = append(s.events.items, s.name + ":update")
}

func (s *testState) Draw(g *voplay.GameCtx) {
	s.drawCount++
	s.events.items = append(s.events.items, s.name + ":draw")
}

func (s *testState) OnResize(g *voplay.GameCtx, w int, h int) {
	s.resizeCount++
	s.events.items = append(s.events.items, s.name + ":resize")
}

func (s *testState) BlocksUpdateBelow() bool {
	return s.blockUpdateBelow
}

func (s *testState) BlocksDrawBelow() bool {
	return s.blockDrawBelow
}

func newTestCtx() *voplay.GameCtx {
	ctx := &voplay.GameCtx{Input: voplay.NewInputState(), Draw: voplay.NewDrawCtx(), Width: 640, Height: 480, FixedStep: 1.0 / 60.0}
	ctx.Actions = voplay.NewActionMap(ctx.Input)
	ctx.Assets = voplay.NewAssetsWithLoaders(newMockAssetLoaders(&assetRuntimeStats{}))
	ctx.States = voplay.NewStateStack(ctx)
	return ctx
}

func newMockAssetLoaders(stats *assetRuntimeStats) voplay.AssetLoaders {
	return voplay.AssetLoaders{Texture: voplay.AssetLoader{LoadFile: func(path string) (int, error) {
		stats.textureLoads++
		stats.fileLoads++
		stats.nextTextureID++
		return stats.nextTextureID, nil
	}, LoadBytes: func(data []byte) (int, error) {
		stats.textureLoads++
		stats.nextTextureID++
		return stats.nextTextureID, nil
	}, Free: func(id int) {
		stats.textureFrees++
	}}, Font: voplay.AssetLoader{LoadFile: func(path string) (int, error) {
		stats.fontLoads++
		stats.fileLoads++
		stats.nextFontID++
		return stats.nextFontID, nil
	}, LoadBytes: func(data []byte) (int, error) {
		stats.fontLoads++
		stats.nextFontID++
		return stats.nextFontID, nil
	}, Free: func(id int) {
		stats.fontFrees++
	}}, Model: voplay.AssetLoader{LoadFile: func(path string) (int, error) {
		stats.modelLoads++
		stats.fileLoads++
		stats.nextModelID++
		return stats.nextModelID, nil
	}, LoadBytes: func(data []byte) (int, error) {
		stats.modelLoads++
		stats.nextModelID++
		return stats.nextModelID, nil
	}, Free: func(id int) {
		stats.modelFrees++
	}}, Audio: voplay.AssetLoader{LoadFile: func(path string) (int, error) {
		stats.audioLoads++
		stats.fileLoads++
		stats.nextAudioID++
		return stats.nextAudioID, nil
	}, LoadBytes: func(data []byte) (int, error) {
		stats.audioLoads++
		stats.nextAudioID++
		return stats.nextAudioID, nil
	}, Free: func(id int) {
		stats.audioFrees++
	}}, Cubemap: voplay.CubemapLoader{LoadFiles: func(paths [6]string) (int, error) {
		return 1, nil
	}, LoadBytes: func(faces [6][]byte) (int, error) {
		return 1, nil
	}, Free: func(id int) {}}}
}

func assertEvents(events []string, want []string, label string) {
	assert(len(events) == len(want), label + ": len")
	for i := range want {
		assert(events[i] == want[i], label + ": event")
	}
}

func assertFloatNear(got, want, tol float64, label string) {
	diff := got - want
	if diff < 0 {
		diff = -diff
	}
	assert(diff <= tol, label)
}

func assertFloatFar(got, want, tol float64, label string) {
	diff := got - want
	if diff < 0 {
		diff = -diff
	}
	assert(diff > tol, label)
}

func assertVec3Near(got, want voplay.Vec3, tol float64, label string) {
	assertFloatNear(got.X, want.X, tol, label + ": x")
	assertFloatNear(got.Y, want.Y, tol, label + ": y")
	assertFloatNear(got.Z, want.Z, tol, label + ": z")
}

func assertFiniteFloat(got float64, label string) {
	assert(!math.IsNaN(got) && !math.IsInf(got, 0), label)
}

func assertFiniteVec3(got voplay.Vec3, label string) {
	assertFiniteFloat(got.X, label + ": x")
	assertFiniteFloat(got.Y, label + ": y")
	assertFiniteFloat(got.Z, label + ": z")
}

func assertQuatNear(got, want voplay.Quat, tol float64, label string) {
	assertFloatNear(got.X, want.X, tol, label + ": x")
	assertFloatNear(got.Y, want.Y, tol, label + ": y")
	assertFloatNear(got.Z, want.Z, tol, label + ": z")
	assertFloatNear(got.W, want.W, tol, label + ": w")
}

func capturePanic(fn func()) (any, bool) {
	var recovered any
	var didPanic bool
	func() {
		defer func() {
			recovered = recover()
			didPanic = recovered != nil
		}()
		fn()
	}()
	return recovered, didPanic
}

