		perfSummaryJSONFloat(frame.RendererCpu.MainPassMs) +
		",\"rendererPostPassMs\":" +
		perfSummaryJSONFloat(frame.RendererCpu.PostPassMs) +
		",\"rendererOverlayPassMs\":" +
		perfSummaryJSONFloat(frame.RendererCpu.OverlayPassMs) +
		",\"rendererQueueSubmitCpuMs\":" +
		perfSummaryJSONFloat(frame.RendererCpu.QueueSubmitCpuMs) +
		",\"rendererPresentCpuMs\":" +
		perfSummaryJSONFloat(frame.RendererCpu.PresentCpuMs) +
		",\"drawBytes\":" +
		strconv.Itoa(frame.Framewire.DrawBytes) +
		",\"submitBytes\":" +
		strconv.Itoa(frame.Framewire.SubmitBytes) +
		",\"renderDrawBytes\":" +
		strconv.Itoa(frame.RenderWorker.DrawBytes) +
		",\"hudCpuMs\":" +
		perfSummaryJSONFloat(frame.Hud.CpuMs) +
		"}"
}

func perfSummaryJSONFloat(value float64) string {
	return strconv.FormatFloat(value, 'f', 2, 64)
}

func perfSummaryJSONBool(value bool) string {
	if value {
		return "true"
	}
	return "false"
}

func perfSummaryJSONString(value string) string {
	out := "\""
	for i := 0; i < len(value); i++ {
		ch := value[i:i + 1]
		if ch == "\\" {
			out += "\\\\"
		} else if ch == "\"" {
			out += "\\\""
		} else {
			out += ch
		}
	}
	return out + "\""
}
