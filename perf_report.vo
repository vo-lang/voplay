func EncodePerfSkipSummaryReport(source string, frame int, workload PerfRendererWorkloadStats) string {
	return "{" + "\"schemaVersion\":1" + ",\"source\":" + perfSummaryJSONString(source) +
		",\"kind\":\"perf-skip-summary\"" +
		",\"frame\":" +
		strconv.Itoa(frame) +
		",\"workload\":{" +
		"\"filteredDraws\":" +
		strconv.Itoa(workload.FilteredDraws) +
		",\"missingResources\":" +
		strconv.Itoa(workload.MissingResources) +
		",\"invalidBatches\":" +
		strconv.Itoa(workload.InvalidBatches) +
		",\"fallbackPaths\":" +
		strconv.Itoa(workload.FallbackPaths) +
		",\"missingModels\":" +
		strconv.Itoa(workload.MissingModels) +
		",\"missingMeshes\":" +
		strconv.Itoa(workload.MissingMeshes) +
		",\"missingTextures\":" +
		strconv.Itoa(workload.MissingTextures) +
		",\"missingBindGroups\":" +
		strconv.Itoa(workload.MissingBindGroups) +
		",\"missingChunks\":" +
		strconv.Itoa(workload.MissingChunks) +
		",\"missingTargets\":" +
		strconv.Itoa(workload.MissingTargets) +
		",\"invalidBatchIndices\":" +
		strconv.Itoa(workload.InvalidBatchIndices) +
		",\"incompatibleDraws\":" +
		strconv.Itoa(workload.IncompatibleDraws) +
		"}" +
		"}"
}

func perfSummaryLatestSpike(snapshot PerfSnapshot) PerfSpike {
	if snapshot.RecentSpikeCount <= 0 || len(snapshot.RecentSpikes) <= 0 {
		return PerfSpike{}
	}
	limit := snapshot.RecentSpikeCount
	if limit > len(snapshot.RecentSpikes) {
		limit = len(snapshot.RecentSpikes)
	}
	return snapshot.RecentSpikes[limit - 1]
}

func perfSummarySpikeJSON(spike PerfSpike) string {
	return "{" + "\"frame\":" + strconv.Itoa(spike.FrameId) + ",\"frameMs\":" +
		perfSummaryJSONFloat(spike.FrameMs) +
		",\"overBudgetMs\":" +
		perfSummaryJSONFloat(spike.OverBudgetMs) +
		",\"cause\":" +
		perfSummaryJSONString(spike.PrimaryCause) +
		",\"secondaryCause\":" +
		perfSummaryJSONString(spike.SecondaryCause) +
		",\"evidence\":" +
		perfSummaryJSONString(spike.Evidence) +
		",\"gameCpuMs\":" +
		perfSummaryJSONFloat(spike.GameCpuMs) +
		",\"fixedSteps\":" +
		strconv.Itoa(spike.FixedSteps) +
		",\"drawEncodeMs\":" +
		perfSummaryJSONFloat(spike.DrawEncodeMs) +
		",\"renderLoopMs\":" +
		perfSummaryJSONFloat(spike.RenderLoopMs) +
		",\"displayPulseMs\":" +
		perfSummaryJSONFloat(spike.RenderDisplayPulseMs) +
		",\"paceWaitMs\":" +
		perfSummaryJSONFloat(spike.RenderPaceWaitMs) +
		",\"replyWaitMs\":" +
		perfSummaryJSONFloat(spike.RenderReplyWaitMs) +
		",\"submitCpuMs\":" +
		perfSummaryJSONFloat(spike.RenderSubmitMs) +
		",\"renderWorkMs\":" +
		perfSummaryJSONFloat(spike.RenderWorkMs) +
		",\"inputPollMs\":" +
		perfSummaryJSONFloat(spike.RenderInputPollMs) +
		",\"requestSendMs\":" +
		perfSummaryJSONFloat(spike.RenderRequestSendMs) +
		",\"requestEncodeMs\":" +
		perfSummaryJSONFloat(spike.RenderRequestEncodeMs) +
		",\"requestPortSendMs\":" +
		perfSummaryJSONFloat(spike.RenderRequestPortSendMs) +
		",\"perfPacketMs\":" +
		perfSummaryJSONFloat(spike.RenderPerfPacketMs) +
		",\"gpuWorkDoneMs\":" +
		perfSummaryJSONFloat(spike.GpuWorkDoneMs) +
		",\"gpuInFlight\":" +
		strconv.Itoa(spike.GpuInFlight) +
		",\"drawBytes\":" +
		strconv.Itoa(spike.DrawBytes) +
		",\"submitBytes\":" +
		strconv.Itoa(spike.SubmitBytes) +
		",\"hudCpuMs\":" +
		perfSummaryJSONFloat(spike.HudCpuMs) +
		"}"
}

