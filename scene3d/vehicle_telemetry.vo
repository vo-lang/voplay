package scene3d

import (
	"github.com/vo-lang/voplay"
)

const (
	VehicleTelemetryIssueInvalidNumber = "vehicle.invalid_number"
	VehicleTelemetryIssueInvalidQuaternion = "vehicle.invalid_quaternion"
	VehicleTelemetryIssueExcessiveVelocity = "vehicle.excessive_velocity"
	VehicleTelemetryIssueStuck = "vehicle.stuck"
)

type VehicleTelemetry struct {
	Position voplay.Vec3
	Rotation voplay.Quat
	Velocity voplay.Vec3
	AngularVelocity voplay.Vec3
	Speed float64
	SignedSpeed float64
	ForwardSpeed float64
	LateralSpeed float64
	Yaw float64
	Grounded bool
	GroundNormal voplay.Vec3
	GroundPoint voplay.Vec3
	WheelCount int
	ContactCount int
	MaxSuspensionCompression float64
	MaxLongitudinalSlip float64
	MaxLateralSlip float64
	SurfaceID string
	Surface SurfaceMaterial
	SurfaceBlend SurfaceMaterialBlend
	WheelContacts []WheelContactSample
	WheelTelemetry []WheelTelemetry
	BackendApplyHash int
	AirborneTime float64
	LastImpulse float64
	LastTangentImpulse float64
	InvalidSampleCount int
	Drifting bool
	Boosting bool
	Recovery VehicleRecoveryState
}

type WheelTelemetry struct {
	WheelIndex int
	SurfaceID MaterialID
	Contact WheelContactSample
}

type VehicleTelemetryIssue struct {
	Code string
	Severity int
	Detail string
}

type VehicleTelemetryBudget struct {
	MaxVelocity float64
	StuckSpeed float64
	StuckThrottle float64
}

func DefaultVehicleTelemetryBudget() VehicleTelemetryBudget {
	return VehicleTelemetryBudget{MaxVelocity: 120, StuckSpeed: 0.35, StuckThrottle: 0.75}
}

func VehicleTelemetryFromVehicle(vehicle *Vehicle) VehicleTelemetry {
	if vehicle == nil {
		return VehicleTelemetry{}
	}
	currentSurface := vehicle.CurrentSurfaceMaterial()
	rawSpeed := vehicle.Speed
	rawYaw := vehicle.Yaw
	rawGroundNormal := vehicle.GroundNormal
	rawGroundPoint := vehicle.GroundPoint
	rawPosition := voplay.Vec3{}
	rawRotation := voplay.QuatIdentity()
	rawVelocity := voplay.Vec3{}
	rawAngularVelocity := voplay.Vec3{}
	invalidSamples := vehicle.RawInvalidSampleCount
	if !vehicleFinite(rawSpeed) || !vehicleFinite(rawYaw) || !vehicleVec3Finite(rawGroundNormal) || !vehicleVec3Finite(rawGroundPoint) {
		invalidSamples++
	}
	if vehicle.Body != nil {
		rawPosition = vehicle.Body.Position()
		rawRotation = vehicle.Body.Rotation()
		if !vehicleVec3Finite(rawPosition) || !vehicleQuatFinite(rawRotation) || !vehicleQuatUnit(rawRotation) {
			invalidSamples++
		}
		if vehicle.Body.Physics != nil {
			rawVelocity = vehicle.Body.Physics.velocity
			rawAngularVelocity = vehicle.Body.Physics.angularVelocity
			if !vehicleVec3Finite(rawVelocity) || !vehicleVec3Finite(rawAngularVelocity) {
				invalidSamples++
			}
		}
	}
	t := VehicleTelemetry{Speed: vehicleFiniteOr(rawSpeed, 0), SignedSpeed: vehicleFiniteOr(rawSpeed, 0), Yaw: vehicleFiniteOr(rawYaw, 0), Grounded: vehicle.Grounded, GroundNormal: vehicleCleanNormal(rawGroundNormal), GroundPoint: vehicleCleanVec3(rawGroundPoint), WheelCount: vehicle.WheelCount(), Surface: currentSurface, SurfaceBlend: SurfaceMaterialBlend{Primary: currentSurface}, BackendApplyHash: vehicle.LastBackendApplyCommand.DebugHash, InvalidSampleCount: invalidSamples, Drifting: vehicle.Drifting || vehicle.LastForceCommand.Drifting, Boosting: vehicle.LastForceCommand.Boosting}
	if vehicle.Body != nil {
		t.Position = vehicleCleanVec3(rawPosition)
		t.Rotation = vehicleCleanQuat(rawRotation)
		if vehicle.Body.Physics != nil {
			t.Velocity = vehicleCleanVec3(rawVelocity)
			t.AngularVelocity = vehicleCleanVec3(rawAngularVelocity)
		}
	}
	forward, lateral := vehicle.localWheelSlipVelocity()
	if !vehicleFinite(forward) || !vehicleFinite(lateral) {
		t.InvalidSampleCount++
	}
	t.ForwardSpeed = vehicleFiniteOr(forward, 0)
	t.LateralSpeed = vehicleFiniteOr(lateral, 0)
	for i := 0; i < vehicle.WheelCount(); i++ {
		wheel, ok := vehicle.WheelState(i)
		if !ok {
			continue
		}
		surface := t.Surface
		if wheel.SurfaceID != "" || wheel.Surface.ID != "" || wheel.Surface.Kind != "" {
			surface = vehicle.surfaceMaterialForWheel(wheel)
		}
		sample := WheelContactSample{WheelIndex: i, HitPoint: wheel.ContactPoint, Normal: wheel.ContactNormal, Compression: wheel.SuspensionCompression, Surface: surface, ForwardSlip: wheel.LongitudinalSlip, SideSlip: wheel.LateralSlip, Load: wheel.NormalLoad, Grip: surface.GripScale, InContact: wheel.InContact}
		t.WheelContacts = append(t.WheelContacts, sample)
		t.WheelTelemetry = append(t.WheelTelemetry, WheelTelemetry{WheelIndex: i, SurfaceID: MaterialID(surface.ID), Contact: sample})
		if wheel.InContact {
			t.ContactCount++
			if t.SurfaceID == "" && wheel.SurfaceID != "" {
				t.SurfaceID = wheel.SurfaceID
			}
		}
		if wheel.SuspensionCompression > t.MaxSuspensionCompression {
			t.MaxSuspensionCompression = wheel.SuspensionCompression
		}
		if wheel.LongitudinalSlip > t.MaxLongitudinalSlip {
			t.MaxLongitudinalSlip = wheel.LongitudinalSlip
		}
		if wheel.LateralSlip > t.MaxLateralSlip {
			t.MaxLateralSlip = wheel.LateralSlip
		}
	}
	if t.SurfaceID == "" {
		t.SurfaceID = t.Surface.ID
	}
	if !t.Grounded {
		t.AirborneTime = 1.0 / 60.0
	}
	if vehicle.Body != nil && vehicle.Body.scene != nil {
		for _, event := range vehicle.Body.scene.ContactEvents() {
			if event.A == vehicle.Body || event.B == vehicle.Body {
				t.LastImpulse = event.NormalImpulse
				t.LastTangentImpulse = event.TangentImpulse
				break
			}
		}
	}
	return t
}

func (v *Vehicle) Telemetry() VehicleTelemetry {
	return VehicleTelemetryFromVehicle(v)
}

func ProductVehicleTelemetry(vehicle *Vehicle) VehicleTelemetry {
	return VehicleTelemetryFromVehicle(vehicle)
}

func (t VehicleTelemetry) ValidationIssues(intent VehicleIntent, budget VehicleTelemetryBudget) []VehicleTelemetryIssue {
	budget = normalizeVehicleTelemetryBudget(budget)
	issues := []VehicleTelemetryIssue{}
	if !vehicleVec3Finite(t.Position) || !vehicleVec3Finite(t.Velocity) || !vehicleVec3Finite(t.AngularVelocity) || !vehicleVec3Finite(t.GroundNormal) || !vehicleFinite(t.Speed) || !vehicleFinite(t.Yaw) {
		issues = append(issues, VehicleTelemetryIssue{Code: VehicleTelemetryIssueInvalidNumber, Severity: 1, Detail: "non-finite vehicle telemetry"})
	}
	if t.InvalidSampleCount > 0 {
		issues = append(issues, VehicleTelemetryIssue{Code: VehicleTelemetryIssueInvalidNumber, Severity: 1, Detail: "invalid telemetry sample count"})
	}
	if !vehicleQuatFinite(t.Rotation) || !vehicleQuatUnit(t.Rotation) {
		issues = append(issues, VehicleTelemetryIssue{Code: VehicleTelemetryIssueInvalidQuaternion, Severity: 1, Detail: "invalid vehicle orientation"})
	}
	if t.Velocity.Length() > budget.MaxVelocity || t.Speed > budget.MaxVelocity {
		issues = append(issues, VehicleTelemetryIssue{Code: VehicleTelemetryIssueExcessiveVelocity, Severity: 1, Detail: "vehicle velocity exceeds budget"})
	}
	intent = intent.Normalized()
	if t.Grounded && t.Speed <= budget.StuckSpeed && intent.Throttle >= budget.StuckThrottle {
		issues = append(issues, VehicleTelemetryIssue{Code: VehicleTelemetryIssueStuck, Severity: 2, Detail: "vehicle is grounded but not moving under throttle"})
	}
	return issues
}

func (t VehicleTelemetry) IsHealthy(intent VehicleIntent, budget VehicleTelemetryBudget) bool {
	return len(t.ValidationIssues(intent, budget)) == 0
}

func normalizeVehicleTelemetryBudget(budget VehicleTelemetryBudget) VehicleTelemetryBudget {
	defaults := DefaultVehicleTelemetryBudget()
	if budget.MaxVelocity <= 0 {
		budget.MaxVelocity = defaults.MaxVelocity
	}
	if budget.StuckSpeed <= 0 {
		budget.StuckSpeed = defaults.StuckSpeed
	}
	if budget.StuckThrottle <= 0 {
		budget.StuckThrottle = defaults.StuckThrottle
	}
	return budget
}

func vehicleCleanQuat(q voplay.Quat) voplay.Quat {
	if !vehicleQuatFinite(q) || q.X * q.X + q.Y * q.Y + q.Z * q.Z + q.W * q.W == 0 {
		return voplay.QuatIdentity()
	}
	return q.Normalize()
}

func vehicleFinite(v float64) bool {
	return vehicleFiniteOr(v, 42) == v
}

func vehicleVec3Finite(v voplay.Vec3) bool {
	return vehicleFinite(v.X) && vehicleFinite(v.Y) && vehicleFinite(v.Z)
}

func vehicleQuatFinite(q voplay.Quat) bool {
	return vehicleFinite(q.X) && vehicleFinite(q.Y) && vehicleFinite(q.Z) && vehicleFinite(q.W)
}

func vehicleQuatUnit(q voplay.Quat) bool {
	lengthSq := q.X * q.X + q.Y * q.Y + q.Z * q.Z + q.W * q.W
	return lengthSq > 0.98 && lengthSq < 1.02
}
