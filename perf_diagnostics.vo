func (g *GameCtx) EnablePerfStats(mode string) {
	if g.overlay == nil {
		g.overlay = newDebugOverlay(0)
	}
	g.overlay.setPerfMode(mode)
}

func (g *GameCtx) DisablePerfStats() {
	if g.overlay == nil {
		return
	}
	g.overlay.setPerfMode(PerfModeOff)
}

func (g *GameCtx) TogglePerfHud() {
	if g.overlay == nil {
		g.overlay = newDebugOverlay(0)
	}
	if !g.overlay.perf.enabled || !g.overlay.perf.hudVisible {
		g.overlay.setPerfMode(PerfModeHud)
		return
	}
	g.overlay.setPerfMode(PerfModeStats)
}

func (g *GameCtx) NextPerfHudPage() {
	if g.overlay == nil {
		g.overlay = newDebugOverlay(0)
	}
	g.overlay.perf.nextHudPage()
}

func (g *GameCtx) GetPerfSnapshot() PerfSnapshot {
	if g.overlay == nil {
		return PerfSnapshot{Mode: PerfModeOff, BudgetMs: perfBudgetMs(0), WindowCapacity: perfFrameRingSize}
	}
	return g.overlay.perfSnapshot()
}

func (g *GameCtx) GetPerfTrace(maxFrames int) PerfTrace {
	if g.overlay == nil {
		snapshot := g.GetPerfSnapshot()
		return PerfTrace{SchemaVersion: 1, Enabled: false, Mode: snapshot.Mode, BudgetMs: snapshot.BudgetMs}
	}
	return g.overlay.perfTrace(maxFrames)
}

func (g *GameCtx) EvaluatePerfGate(config PerfGateConfig) PerfGateResult {
	return EvaluatePerfGate(g.GetPerfSnapshot(), config)
}

func (g *GameCtx) MarkPerfScope(name string) {
	if g.overlay == nil {
		return
	}
	g.overlay.perf.recordCustomScope(name, 0)
}

func (g *GameCtx) BeginPerfScope(name string) PerfScopeHandle {
	return PerfScopeHandle{Name: name, start: time.Now(), active: true}
}

func (g *GameCtx) EndPerfScope(handle PerfScopeHandle) {
	if g.overlay == nil || !handle.active {
		return
	}
	elapsedMs := float64(time.Now().Sub(handle.start).Nanoseconds()) / 1e6
	g.overlay.perf.recordCustomScope(handle.Name, elapsedMs)
}

func (o *DebugOverlay) drawPerfHud(d *DrawCtx) {
	if !o.enabled || !o.hudVisible {
		return
	}
	o.refreshDisplayStrings()
	d.ResetCamera()
	d.SetLayer(65535)
	panelX := 12.0
	panelY := 14.0
	panelW := 560.0
	panelH := 270.0
	d.DrawRect(panelX, panelY, panelW, panelH, Color{R: 0, G: 0, B: 0, A: 0.65})
	page := o.perf.hudPage
	if page == 1 {
		o.drawPerfTimelinePage(d, panelX, panelY, panelW, panelH)
	} else if page == 2 {
		o.drawPerfWorkloadPage(d, panelX, panelY)
	} else if page == 3 {
		o.drawPerfGpuPage(d, panelX, panelY)
	} else if page == 4 {
		o.drawPerfSpikePage(d, panelX, panelY)
	} else if page == 5 {
		o.drawPerfScenePage(d, panelX, panelY)
	} else {
		o.drawPerfOverviewPage(d, panelX, panelY)
	}
}

func (o *DebugOverlay) drawPerfOverviewPage(d *DrawCtx, panelX, panelY float64) {
	snapshot := o.perfSnapshot()
	textX := panelX + 10.0
	y := panelY + 16.0
	fontSize := 14.0
	lineH := 18.0
	textColor := Color{R: 0.0, G: 1.0, B: 0.0, A: 1.0}
	d.DrawText("perf overview  page " + strconv.Itoa(o.perf.hudPage + 1) + "/6", textX, y, fontSize, textColor)
	y += lineH
	d.DrawText("present: "+o.dispFPS+"  classify "+snapshot.Current.Classification.PrimaryCause, textX, y, fontSize, textColor)
	y += lineH
	d.DrawText("frame: "+o.dispFrameMs+"  "+o.dispBudget, textX, y, fontSize, textColor)
	y += lineH
	d.DrawText("logic: "+o.dispLogicMs+"  headroom "+o.dispLogicFPS, textX, y, fontSize, textColor)
	y += lineH
	d.DrawText(o.dispBytes+"  fixed "+strconv.Itoa(o.fixedSteps), textX, y, fontSize, textColor)
	y += lineH
	d.DrawText(o.dispPhases, textX, y, fontSize, textColor)
	y += lineH
	d.DrawText(o.dispWindowFrame, textX, y, fontSize, textColor)
	y += lineH
	d.DrawText(o.dispRenderWindow, textX, y, fontSize, textColor)
	y += lineH
	d.DrawText("30s slow "+strconv.Itoa(snapshot.ThirtySecond.SlowFrames)+"/"+strconv.Itoa(snapshot.ThirtySecond.Frames)+"  mixed "+strconv.Itoa(snapshot.Attribution.Mixed)+" gpu "+strconv.Itoa(snapshot.Attribution.GpuQueueBound)+" hud "+strconv.Itoa(snapshot.Attribution.HudOverhead), textX, y, fontSize, textColor)
	y += lineH
	d.DrawText(o.dispMax+"  spikes "+strconv.Itoa(snapshot.RecentSpikeCount), textX, y, fontSize, textColor)
}

func (o *DebugOverlay) drawPerfTimelinePage(d *DrawCtx, panelX, panelY, panelW, panelH float64) {
	textColor := Color{R: 0.0, G: 1.0, B: 0.0, A: 1.0}
	d.DrawText("perf timeline 240f", panelX + 10, panelY + 16, 14, textColor)
	graphX := panelX + 10.0
	graphY := panelY + 44.0
	graphW := panelW - 20.0
	graphH := panelH - 62.0
	d.DrawLine(graphX, graphY + graphH - graphH * o.frameBudgetMs / 50.0, graphX + graphW, graphY + graphH - graphH * o.frameBudgetMs / 50.0, 1, Color{R: 0.2, G: 0.9, B: 0.2, A: 0.8})
	d.DrawLine(graphX, graphY + graphH - graphH * 16.667 / 50.0, graphX + graphW, graphY + graphH - graphH * 16.667 / 50.0, 1, Color{R: 0.9, G: 0.8, B: 0.2, A: 0.8})
	barW := graphW / 240.0
	for i := 0; i < 240; i++ {
		frame, ok := o.perf.recentFrameSample(239 - i)
		if ok {
			ms := frame.FrameMs
			if ms > 50 {
				ms = 50
			}
			h := graphH * ms / 50.0
			color := perfCauseColor(frame.Cause)
			d.DrawRect(graphX + float64(i) * barW, graphY + graphH - h, barW, h, color)
		}
	}
	d.DrawText("p50/p90/p99 "+perfFormatMs(o.perf.thirtySecond.summary().FrameP50Ms)+"/"+perfFormatMs(o.perf.thirtySecond.summary().FrameP90Ms)+"/"+perfFormatMs(o.perf.thirtySecond.summary().FrameP99Ms), panelX + 10, panelY + panelH - 12, 12, textColor)
}

func (o *DebugOverlay) drawPerfWorkloadPage(d *DrawCtx, panelX, panelY float64) {
	snapshot := o.perfSnapshot()
	w := snapshot.Current.RendererWorkload
	y := panelY + 16.0
	textX := panelX + 10.0
	lineH := 19.0
	c := Color{R: 0.0, G: 1.0, B: 0.0, A: 1.0}
	d.DrawText("perf workload", textX, y, 14, c)
	y += lineH
	d.DrawText("draw calls "+strconv.Itoa(w.DrawCalls)+" model "+strconv.Itoa(w.ModelDraws)+" primitive "+strconv.Itoa(w.PrimitiveDraws)+" sprite "+strconv.Itoa(w.SpriteDraws)+" text "+strconv.Itoa(w.TextDraws), textX, y, 14, c)
	y += lineH
	d.DrawText("instances "+strconv.Itoa(w.Instances)+" triangles "+strconv.Itoa(w.Triangles)+" upload "+formatDebugBytes(w.UploadBytes), textX, y, 14, c)
	y += lineH
	d.DrawText("resources buffers "+strconv.Itoa(w.BufferCreates)+" textures "+strconv.Itoa(w.TextureUploads)+" bindgroups "+strconv.Itoa(w.BindGroupCreates)+" chunks "+strconv.Itoa(w.ResidentChunkRebuilds), textX, y, 14, c)
	y += lineH
	d.DrawText("shadow cascades "+strconv.Itoa(w.ShadowCascades)+" primitive chunks "+strconv.Itoa(w.PrimitiveChunks)+" post effects "+strconv.Itoa(w.PostEffects), textX, y, 14, c)
	y += lineH
	d.DrawText("renderer diag "+PerfRendererDiagnosticLabel(w.DiagnosticFlags), textX, y, 14, c)
	y += lineH
	d.DrawText("host draw bytes "+formatDebugBytes(snapshot.Current.Framewire.DrawBytes)+" submit bytes "+formatDebugBytes(snapshot.Current.Framewire.SubmitBytes), textX, y, 14, c)
	y += lineH
	d.DrawText("draw encode p90 "+perfFormatMs(snapshot.ThirtySecond.DrawEncodeP90Ms)+" render submit p90 "+perfFormatMs(snapshot.ThirtySecond.RenderSubmitP90Ms), textX, y, 14, c)
}

func (o *DebugOverlay) drawPerfGpuPage(d *DrawCtx, panelX, panelY float64) {
	snapshot := o.perfSnapshot()
	gpu := snapshot.Current.GpuQueue
	present := snapshot.Current.Present
	y := panelY + 16.0
	textX := panelX + 10.0
	lineH := 19.0
	c := Color{R: 0.0, G: 1.0, B: 0.0, A: 1.0}
	d.DrawText("perf gpu", textX, y, 14, c)
	y += lineH
	d.DrawText("queue "+gpu.QueueDepthClass+" submitCpu "+perfFormatMs(gpu.SubmitCpuMs)+" workDone "+perfFormatMs(gpu.SubmittedWorkDoneMs), textX, y, 14, c)
	y += lineH
	d.DrawText("inFlight "+strconv.Itoa(gpu.InFlightSubmits)+" submits "+strconv.Itoa(gpu.SubmitCount)+" sampleRate "+strconv.FormatFloat(gpu.SampleRate, 'f', 2, 64), textX, y, 14, c)
	y += lineH
	d.DrawText("surface acquire "+perfFormatMs(present.SurfaceAcquireMs)+" present "+perfFormatMs(present.PresentCpuMs)+" backpressure "+perfFormatMs(present.BackpressureMs), textX, y, 14, c)
	y += lineH
	d.DrawText("probe overhead "+perfFormatMs(gpu.ProbeOverheadMs)+" gpu p90 "+perfFormatMs(snapshot.ThirtySecond.GpuWorkDoneP90Ms), textX, y, 14, c)
	y += lineH
	d.DrawText("render pulse "+perfFormatMs(snapshot.Current.RenderWorker.DisplayPulseMs)+" pace "+perfFormatMs(snapshot.Current.RenderWorker.PaceWaitMs)+" loop "+perfFormatMs(snapshot.Current.RenderWorker.LoopTotalMs), textX, y, 14, c)
}

func (o *DebugOverlay) drawPerfSpikePage(d *DrawCtx, panelX, panelY float64) {
	snapshot := o.perfSnapshot()
	y := panelY + 16.0
	textX := panelX + 10.0
	lineH := 19.0
	c := Color{R: 0.0, G: 1.0, B: 0.0, A: 1.0}
	d.DrawText("perf spike log", textX, y, 14, c)
	y += lineH
	count := snapshot.RecentSpikeCount
	if count > 8 {
		count = 8
	}
	for i := 0; i < count; i++ {
		spike := snapshot.RecentSpikes[i]
		d.DrawText("#"+strconv.Itoa(spike.FrameId)+" "+perfFormatMs(spike.FrameMs)+" +"+perfFormatMs(spike.OverBudgetMs)+" "+spike.PrimaryCause+" "+spike.Evidence, textX, y, 13, c)
		y += lineH
	}
	if count == 0 {
		d.DrawText("no budget spikes recorded", textX, y, 14, c)
	}
}

func (o *DebugOverlay) drawPerfScenePage(d *DrawCtx, panelX, panelY float64) {
	snapshot := o.perfSnapshot()
	scene := snapshot.Current.Scene
	y := panelY + 16.0
	textX := panelX + 10.0
	lineH := 19.0
	c := Color{R: 0.0, G: 1.0, B: 0.0, A: 1.0}
	d.DrawText("perf scene", textX, y, 14, c)
	y += lineH
	d.DrawText("entities "+strconv.Itoa(scene.EntityCount)+" visible "+strconv.Itoa(scene.VisibleCount)+" culled "+strconv.Itoa(scene.CulledCount), textX, y, 14, c)
	y += lineH
	d.DrawText("models "+strconv.Itoa(scene.ModelCount)+" primitives "+strconv.Itoa(scene.PrimitiveCount)+" chunks "+strconv.Itoa(scene.PrimitiveChunkCount), textX, y, 14, c)
	y += lineH
	d.DrawText("shadow "+perfBoolString(scene.ShadowEnabled)+" quality "+strconv.Itoa(scene.ShadowQuality)+" debug "+strconv.Itoa(scene.RenderDebugMode), textX, y, 14, c)
	y += lineH
	d.DrawText("custom scopes", textX, y, 14, c)
	y += lineH
	count := snapshot.CustomScopeCount
	for i := 0; i < count; i++ {
		d.DrawText(perfSnapshotCustomScopeName(&snapshot, i)+" last "+perfFormatMs(perfSnapshotCustomScopeLastMs(&snapshot, i))+" max "+perfFormatMs(perfSnapshotCustomScopeMaxMs(&snapshot, i))+" count "+strconv.Itoa(perfSnapshotCustomScopeCount(&snapshot, i)), textX, y, 13, c)
		y += lineH
	}
}

func perfCauseColor(cause string) Color {
	if cause == PerfCauseLogicCpuBound {
		return Color{R: 0.95, G: 0.45, B: 0.18, A: 0.9}
	}
	if cause == PerfCauseGpuQueueBound {
		return Color{R: 0.45, G: 0.65, B: 1.0, A: 0.9}
	}
	if cause == PerfCauseHudOverhead {
		return Color{R: 1.0, G: 0.25, B: 0.8, A: 0.9}
	}
	if cause == PerfCauseMixed {
		return Color{R: 1.0, G: 0.2, B: 0.2, A: 0.9}
	}
	if cause == PerfCauseFramewireBound || cause == PerfCauseRenderCpuBound {
		return Color{R: 0.95, G: 0.8, B: 0.2, A: 0.9}
	}
	return Color{R: 0.15, G: 0.85, B: 0.25, A: 0.75}
}

// PerfSummaryFixedStats carries product-owned fixed-step timing alongside engine perf facts.
type PerfSummaryFixedStats struct {
	TotalMs float64
	PeakTotalMs float64
	SlowFrames int
	Frames int
	SlowestPhase string
	SlowestPhaseMs float64
	MaxSlowFrames int
}

func EncodePerfSummaryReport(source string, frame int, snapshot PerfSnapshot, window PerfWindowSummary, status string, gate PerfGateResult, fixed PerfSummaryFixedStats, screen ScreenMetrics) string {
	current := snapshot.Current
	renderer := current.RendererCpu
	workload := current.RendererWorkload
	gpu := current.GpuQueue
	hist := snapshot.SlowHistogram
	latestSpike := perfSummaryLatestSpike(snapshot)
	windowWorst := snapshot.WindowWorstFrame
	screenMPixels := float64(screen.PixelWidth * screen.PixelHeight) / 1000000.0
	return "{" + "\"schemaVersion\":1" + ",\"source\":" + perfSummaryJSONString(source) + ",\"kind\":\"perf-summary\"" + ",\"frame\":" + strconv.Itoa(frame) + ",\"mode\":" + perfSummaryJSONString(snapshot.Mode) + ",\"status\":" + perfSummaryJSONString(status) + ",\"gatePassed\":" + perfSummaryJSONBool(gate.Passed) + ",\"failure\":" + perfSummaryJSONString(gate.PrimaryFailure) + ",\"gate\":{" + "\"checkedFrames\":" + strconv.Itoa(gate.CheckedFrames) + ",\"slowFrames\":" + strconv.Itoa(gate.SlowFrames) + ",\"maxSlowFrames\":" + strconv.Itoa(fixed.MaxSlowFrames) + ",\"frameP99Ms\":" + perfSummaryJSONFloat(gate.FrameP99Ms) + ",\"frameMaxMs\":" + perfSummaryJSONFloat(gate.FrameMaxMs) + ",\"activeWorkP90Ms\":" + perfSummaryJSONFloat(gate.ActiveWorkP90Ms) + ",\"activeWorkP99Ms\":" + perfSummaryJSONFloat(gate.ActiveWorkP99Ms) + "}" + ",\"targetHz\":" + strconv.Itoa(snapshot.TargetHz) + ",\"budgetMs\":" + perfSummaryJSONFloat(snapshot.BudgetMs) + ",\"screen\":{" + "\"cssWidth\":" + strconv.Itoa(screen.Width) + ",\"cssHeight\":" + strconv.Itoa(screen.Height) + ",\"pixelWidth\":" + strconv.Itoa(screen.PixelWidth) + ",\"pixelHeight\":" + strconv.Itoa(screen.PixelHeight) + ",\"devicePixelRatio\":" + perfSummaryJSONFloat(screen.DevicePixelRatio) + ",\"mpix\":" + perfSummaryJSONFloat(screenMPixels) + "}" + ",\"window\":{" + "\"frames\":" + strconv.Itoa(window.Frames) + ",\"slowFrames\":" + strconv.Itoa(window.SlowFrames) + ",\"frameP50Ms\":" + perfSummaryJSONFloat(window.FrameP50Ms) + ",\"frameP90Ms\":" + perfSummaryJSONFloat(window.FrameP90Ms) + ",\"frameP99Ms\":" + perfSummaryJSONFloat(window.FrameP99Ms) + ",\"frameMaxMs\":" + perfSummaryJSONFloat(window.FrameMaxMs) + ",\"gameCpuP90Ms\":" + perfSummaryJSONFloat(window.GameCpuP90Ms) + ",\"drawEncodeP90Ms\":" + perfSummaryJSONFloat(window.DrawEncodeP90Ms) + ",\"renderLoopP90Ms\":" + perfSummaryJSONFloat(window.RenderLoopP90Ms) + ",\"renderWorkP90Ms\":" + perfSummaryJSONFloat(window.RenderWorkP90Ms) + ",\"renderSubmitP90Ms\":" + perfSummaryJSONFloat(window.RenderSubmitP90Ms) + ",\"gpuWorkDoneP90Ms\":" + perfSummaryJSONFloat(window.GpuWorkDoneP90Ms) + ",\"activeWorkP90Ms\":" + perfSummaryJSONFloat(window.ActiveWorkP90Ms) + ",\"activeWorkP99Ms\":" + perfSummaryJSONFloat(window.ActiveWorkP99Ms) + ",\"hudP90Ms\":" + perfSummaryJSONFloat(window.HudP90Ms) + "}" + ",\"histogram\":{" + "\"leBudget\":" + strconv.Itoa(hist.LeBudget) + ",\"le12Ms\":" + strconv.Itoa(hist.Le12Ms) + ",\"le16Ms\":" + strconv.Itoa(hist.Le16Ms) + ",\"le25Ms\":" + strconv.Itoa(hist.Le25Ms) + ",\"le33Ms\":" + strconv.Itoa(hist.Le33Ms) + ",\"le50Ms\":" + strconv.Itoa(hist.Le50Ms) + ",\"le100Ms\":" + strconv.Itoa(hist.Le100Ms) + ",\"gt100Ms\":" + strconv.Itoa(hist.Gt100Ms) + "}" + ",\"classification\":{" + "\"primaryCause\":" + perfSummaryJSONString(current.Classification.PrimaryCause) + ",\"secondaryCause\":" + perfSummaryJSONString(current.Classification.SecondaryCause) + ",\"mixed\":" + perfSummaryJSONBool(current.Classification.Mixed) + ",\"latestSpikeFrame\":" + strconv.Itoa(latestSpike.FrameId) + ",\"latestSpikeMs\":" + perfSummaryJSONFloat(latestSpike.FrameMs) + ",\"latestSpikeCause\":" + perfSummaryJSONString(latestSpike.PrimaryCause) + ",\"windowWorstFrame\":" + strconv.Itoa(windowWorst.FrameId) + ",\"windowWorstMs\":" + perfSummaryJSONFloat(windowWorst.FrameMs) + ",\"windowWorstCause\":" + perfSummaryJSONString(windowWorst.Classification.PrimaryCause) + ",\"latestSpike\":" + perfSummarySpikeJSON(latestSpike) + ",\"windowWorst\":" + perfSummaryFrameBreakdownJSON(windowWorst) + "}" + ",\"current\":{" + "\"frameMs\":" + perfSummaryJSONFloat(current.FrameMs) + ",\"gameCpuMs\":" + perfSummaryJSONFloat(current.GameCpu.TotalMs) + ",\"fixedSteps\":" + strconv.Itoa(current.GameCpu.FixedSteps) + ",\"drawEncodeMs\":" + perfSummaryJSONFloat(current.GameCpu.DrawEncodeMs) + ",\"renderLoopMs\":" + perfSummaryJSONFloat(current.RenderWorker.LoopTotalMs) + ",\"displayPulseMs\":" + perfSummaryJSONFloat(current.RenderWorker.DisplayPulseMs) + ",\"paceWaitMs\":" + perfSummaryJSONFloat(current.RenderWorker.PaceWaitMs) + ",\"frameDivisor\":" + strconv.Itoa(current.RenderWorker.FrameDivisor) + ",\"replyWaitMs\":" + perfSummaryJSONFloat(current.RenderWorker.ReplyWaitMs) + ",\"requestSendMs\":" + perfSummaryJSONFloat(current.RenderWorker.RequestSendMs) + ",\"requestEncodeMs\":" + perfSummaryJSONFloat(current.RenderWorker.RequestEncodeMs) + ",\"requestPortSendMs\":" + perfSummaryJSONFloat(current.RenderWorker.RequestPortSendMs) + ",\"submitCpuMs\":" + perfSummaryJSONFloat(current.RenderWorker.SubmitCpuMs) + ",\"renderWorkMs\":" + perfSummaryJSONFloat(current.RenderWorker.WorkMs) + ",\"gpuWorkDoneMs\":" + perfSummaryJSONFloat(gpu.SubmittedWorkDoneMs) + ",\"gpuQueueDepth\":" + perfSummaryJSONString(gpu.QueueDepthClass) + "}" + ",\"renderer\":{" + "\"submitFrameMs\":" + perfSummaryJSONFloat(renderer.SubmitFrameMs) + ",\"decodeMs\":" + perfSummaryJSONFloat(renderer.DecodeMs) + ",\"sceneUpdateMs\":" + perfSummaryJSONFloat(renderer.SceneUpdateMs) + ",\"depthPassMs\":" + perfSummaryJSONFloat(renderer.DepthPassMs) + ",\"shadowPassMs\":" + perfSummaryJSONFloat(renderer.ShadowPassMs) + ",\"mainPassMs\":" + perfSummaryJSONFloat(renderer.MainPassMs) + ",\"mainPassSetupMs\":" + perfSummaryJSONFloat(renderer.MainPassSetupMs) + ",\"mainSkyboxMs\":" + perfSummaryJSONFloat(renderer.MainSkyboxMs) + ",\"mainModelMs\":" + perfSummaryJSONFloat(renderer.MainModelMs) + ",\"mainPrimitiveMs\":" + perfSummaryJSONFloat(renderer.MainPrimitiveMs) + ",\"mainPassCloseMs\":" + perfSummaryJSONFloat(renderer.MainPassCloseMs) + ",\"waterPassMs\":" + perfSummaryJSONFloat(renderer.WaterPassMs) + ",\"postPassMs\":" + perfSummaryJSONFloat(renderer.PostPassMs) + ",\"overlayPassMs\":" + perfSummaryJSONFloat(renderer.OverlayPassMs) + ",\"queueSubmitCpuMs\":" + perfSummaryJSONFloat(renderer.QueueSubmitCpuMs) + ",\"presentCpuMs\":" + perfSummaryJSONFloat(renderer.PresentCpuMs) + "}" + ",\"workload\":{" + "\"drawCalls\":" + strconv.Itoa(workload.DrawCalls) + ",\"modelDraws\":" + strconv.Itoa(workload.ModelDraws) + ",\"primitiveDraws\":" + strconv.Itoa(workload.PrimitiveDraws) + ",\"waterDraws\":" + strconv.Itoa(workload.WaterDraws) + ",\"waterInstances\":" + strconv.Itoa(workload.WaterInstances) + ",\"waterTriangles\":" + strconv.Itoa(workload.WaterTriangles) + ",\"instancedBatches\":" + strconv.Itoa(workload.InstancedBatches) + ",\"shadowCascades\":" + strconv.Itoa(workload.ShadowCascades) + ",\"primitiveChunks\":" + strconv.Itoa(workload.PrimitiveChunks) + ",\"postEffects\":" + strconv.Itoa(workload.PostEffects) + ",\"instances\":" + strconv.Itoa(workload.Instances) + ",\"triangles\":" + strconv.Itoa(workload.Triangles) + ",\"uploadBytes\":" + strconv.Itoa(workload.UploadBytes) + ",\"bufferCreates\":" + strconv.Itoa(workload.BufferCreates) + ",\"bindGroupCreates\":" + strconv.Itoa(workload.BindGroupCreates) + ",\"textureUploads\":" + strconv.Itoa(workload.TextureUploads) + ",\"residentChunkRebuilds\":" + strconv.Itoa(workload.ResidentChunkRebuilds) + ",\"diagnosticFlags\":" + strconv.Itoa(workload.DiagnosticFlags) + ",\"frameGraphPasses\":" + strconv.Itoa(workload.FrameGraphPasses) + ",\"frameGraphResources\":" + strconv.Itoa(workload.FrameGraphResources) + ",\"frameGraphTargets\":" + strconv.Itoa(workload.FrameGraphTargets) + ",\"frameGraphReadyTargets\":" + strconv.Itoa(workload.FrameGraphReadyTargets) + "}" + ",\"fixed\":{" + "\"totalMs\":" + perfSummaryJSONFloat(fixed.TotalMs) + ",\"peakTotalMs\":" + perfSummaryJSONFloat(fixed.PeakTotalMs) + ",\"slowFrames\":" + strconv.Itoa(fixed.SlowFrames) + ",\"frames\":" + strconv.Itoa(fixed.Frames) + ",\"slowestPhase\":" + perfSummaryJSONString(fixed.SlowestPhase) + ",\"slowestPhaseMs\":" + perfSummaryJSONFloat(fixed.SlowestPhaseMs) + "}" + "}"
}

func perfSummaryLatestSpike(snapshot PerfSnapshot) PerfSpike {
	if snapshot.RecentSpikeCount <= 0 || len(snapshot.RecentSpikes) <= 0 {
		return PerfSpike{}
	}
	limit := snapshot.RecentSpikeCount
	if limit > len(snapshot.RecentSpikes) {
		limit = len(snapshot.RecentSpikes)
	}
	return snapshot.RecentSpikes[limit - 1]
}

func perfSummarySpikeJSON(spike PerfSpike) string {
	return "{" + "\"frame\":" + strconv.Itoa(spike.FrameId) + ",\"frameMs\":" + perfSummaryJSONFloat(spike.FrameMs) + ",\"overBudgetMs\":" + perfSummaryJSONFloat(spike.OverBudgetMs) + ",\"cause\":" + perfSummaryJSONString(spike.PrimaryCause) + ",\"secondaryCause\":" + perfSummaryJSONString(spike.SecondaryCause) + ",\"evidence\":" + perfSummaryJSONString(spike.Evidence) + ",\"gameCpuMs\":" + perfSummaryJSONFloat(spike.GameCpuMs) + ",\"fixedSteps\":" + strconv.Itoa(spike.FixedSteps) + ",\"drawEncodeMs\":" + perfSummaryJSONFloat(spike.DrawEncodeMs) + ",\"renderLoopMs\":" + perfSummaryJSONFloat(spike.RenderLoopMs) + ",\"displayPulseMs\":" + perfSummaryJSONFloat(spike.RenderDisplayPulseMs) + ",\"paceWaitMs\":" + perfSummaryJSONFloat(spike.RenderPaceWaitMs) + ",\"replyWaitMs\":" + perfSummaryJSONFloat(spike.RenderReplyWaitMs) + ",\"submitCpuMs\":" + perfSummaryJSONFloat(spike.RenderSubmitMs) + ",\"renderWorkMs\":" + perfSummaryJSONFloat(spike.RenderWorkMs) + ",\"inputPollMs\":" + perfSummaryJSONFloat(spike.RenderInputPollMs) + ",\"requestSendMs\":" + perfSummaryJSONFloat(spike.RenderRequestSendMs) + ",\"requestEncodeMs\":" + perfSummaryJSONFloat(spike.RenderRequestEncodeMs) + ",\"requestPortSendMs\":" + perfSummaryJSONFloat(spike.RenderRequestPortSendMs) + ",\"perfPacketMs\":" + perfSummaryJSONFloat(spike.RenderPerfPacketMs) + ",\"gpuWorkDoneMs\":" + perfSummaryJSONFloat(spike.GpuWorkDoneMs) + ",\"gpuInFlight\":" + strconv.Itoa(spike.GpuInFlight) + ",\"drawBytes\":" + strconv.Itoa(spike.DrawBytes) + ",\"submitBytes\":" + strconv.Itoa(spike.SubmitBytes) + ",\"hudCpuMs\":" + perfSummaryJSONFloat(spike.HudCpuMs) + "}"
}

func perfSummaryFrameBreakdownJSON(frame PerfFrame) string {
	return "{" + "\"frame\":" + strconv.Itoa(frame.FrameId) + ",\"frameMs\":" + perfSummaryJSONFloat(frame.FrameMs) + ",\"cause\":" + perfSummaryJSONString(frame.Classification.PrimaryCause) + ",\"secondaryCause\":" + perfSummaryJSONString(frame.Classification.SecondaryCause) + ",\"evidence\":" + perfSummaryJSONString(frame.Classification.Evidence) + ",\"gameCpuMs\":" + perfSummaryJSONFloat(frame.GameCpu.TotalMs) + ",\"fixedSteps\":" + strconv.Itoa(frame.GameCpu.FixedSteps) + ",\"drawEncodeMs\":" + perfSummaryJSONFloat(frame.GameCpu.DrawEncodeMs) + ",\"renderLoopMs\":" + perfSummaryJSONFloat(frame.RenderWorker.LoopTotalMs) + ",\"displayPulseMs\":" + perfSummaryJSONFloat(frame.RenderWorker.DisplayPulseMs) + ",\"paceWaitMs\":" + perfSummaryJSONFloat(frame.RenderWorker.PaceWaitMs) + ",\"frameDivisor\":" + strconv.Itoa(frame.RenderWorker.FrameDivisor) + ",\"replyWaitMs\":" + perfSummaryJSONFloat(frame.RenderWorker.ReplyWaitMs) + ",\"submitCpuMs\":" + perfSummaryJSONFloat(frame.RenderWorker.SubmitCpuMs) + ",\"renderWorkMs\":" + perfSummaryJSONFloat(frame.RenderWorker.WorkMs) + ",\"inputPollMs\":" + perfSummaryJSONFloat(frame.RenderWorker.InputPollMs) + ",\"requestSendMs\":" + perfSummaryJSONFloat(frame.RenderWorker.RequestSendMs) + ",\"requestEncodeMs\":" + perfSummaryJSONFloat(frame.RenderWorker.RequestEncodeMs) + ",\"requestPortSendMs\":" + perfSummaryJSONFloat(frame.RenderWorker.RequestPortSendMs) + ",\"perfPacketMs\":" + perfSummaryJSONFloat(frame.RenderWorker.PerfPacketMs) + ",\"gpuWorkDoneMs\":" + perfSummaryJSONFloat(frame.GpuQueue.SubmittedWorkDoneMs) + ",\"gpuInFlight\":" + strconv.Itoa(frame.GpuQueue.InFlightSubmits) + ",\"rendererSubmitFrameMs\":" + perfSummaryJSONFloat(frame.RendererCpu.SubmitFrameMs) + ",\"rendererDecodeMs\":" + perfSummaryJSONFloat(frame.RendererCpu.DecodeMs) + ",\"rendererSceneUpdateMs\":" + perfSummaryJSONFloat(frame.RendererCpu.SceneUpdateMs) + ",\"rendererDepthPassMs\":" + perfSummaryJSONFloat(frame.RendererCpu.DepthPassMs) + ",\"rendererShadowPassMs\":" + perfSummaryJSONFloat(frame.RendererCpu.ShadowPassMs) + ",\"rendererMainPassMs\":" + perfSummaryJSONFloat(frame.RendererCpu.MainPassMs) + ",\"rendererPostPassMs\":" + perfSummaryJSONFloat(frame.RendererCpu.PostPassMs) + ",\"rendererOverlayPassMs\":" + perfSummaryJSONFloat(frame.RendererCpu.OverlayPassMs) + ",\"rendererQueueSubmitCpuMs\":" + perfSummaryJSONFloat(frame.RendererCpu.QueueSubmitCpuMs) + ",\"rendererPresentCpuMs\":" + perfSummaryJSONFloat(frame.RendererCpu.PresentCpuMs) + ",\"drawBytes\":" + strconv.Itoa(frame.Framewire.DrawBytes) + ",\"submitBytes\":" + strconv.Itoa(frame.Framewire.SubmitBytes) + ",\"renderDrawBytes\":" + strconv.Itoa(frame.RenderWorker.DrawBytes) + ",\"hudCpuMs\":" + perfSummaryJSONFloat(frame.Hud.CpuMs) + "}"
}

func perfSummaryJSONFloat(value float64) string {
	return strconv.FormatFloat(value, 'f', 2, 64)
}

func perfSummaryJSONBool(value bool) string {
	if value {
		return "true"
	}
	return "false"
}

func perfSummaryJSONString(value string) string {
	out := "\""
	for i := 0; i < len(value); i++ {
		ch := value[i:i + 1]
		if ch == "\\" {
			out += "\\\\"
		} else if ch == "\"" {
			out += "\\\""
		} else {
			out += ch
		}
	}
	return out + "\""
}
