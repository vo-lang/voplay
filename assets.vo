func (a *Assets) requireCurrentGroup() string {
	group := a.CurrentGroup()
	if group == "" {
		panic("Assets: no active group")
	}
	return group
}

func (a *Assets) group(name string) *assetGroup {
	group := a.groups[name]
	if group == nil {
		panic("Assets: unknown group: " + name)
	}
	return group
}

func (a *Assets) attachTextureOwner(groupName, key string, entry *managedTexture) {
	if entry.owners[groupName] {
		return
	}
	entry.owners[groupName] = true
	group := a.group(groupName)
	group.textures[key] = true
}

func (a *Assets) attachFontOwner(groupName, key string, entry *managedFont) {
	if entry.owners[groupName] {
		return
	}
	entry.owners[groupName] = true
	group := a.group(groupName)
	group.fonts[key] = true
}

func (a *Assets) attachModelOwner(groupName, key string, entry *managedModel) {
	if entry.owners[groupName] {
		return
	}
	entry.owners[groupName] = true
	group := a.group(groupName)
	group.models[key] = true
}

func (a *Assets) attachAudioOwner(groupName, key string, entry *managedAudio) {
	if entry.owners[groupName] {
		return
	}
	entry.owners[groupName] = true
	group := a.group(groupName)
	group.audio[key] = true
}

func requireAssetKey(key string) {
	if key == "" {
		panic("Assets: key must not be empty")
	}
}

func (m *managedTexture) requireSource(kind int, source string) {
	if m.sourceKind != kind || m.source != source {
		panic("Assets.Texture: key reused with different source")
	}
}

func (m *managedFont) requireSource(kind int, source string) {
	if m.sourceKind != kind || m.source != source {
		panic("Assets.Font: key reused with different source")
	}
}

func (m *managedModel) requireSource(kind int, source string) {
	if m.sourceKind != kind || m.source != source {
		panic("Assets.Model: key reused with different source")
	}
}

func (m *managedAudio) requireSource(kind int, source string) {
	if m.sourceKind != kind || m.source != source {
		panic("Assets.Audio: key reused with different source")
	}
}
