func testScene3DSpawnRollback() {
	freed := &intList{}
	mb := &testFreeModelBackend{freed: freed}
	mb.prev = voplay.SetModelBackend(mb)
	defer voplay.SetModelBackend(mb.prev)

	pb := &testScene3DPhysicsBackend{panicOnSpawn: true}
	prevPhys := scene3d.SetPhysicsBackend(pb)
	defer scene3d.SetPhysicsBackend(prevPhys)

	s := scene3d.New()
	_, didPanic := capturePanic(func() {
		s.Spawn(scene3d.EntityDesc{
			OwnedModel: voplay.ModelID(701),
			Physics: &scene3d.Physics{
				Type:     scene3d.Dynamic,
				Collider: scene3d.Box(1, 1, 1),
				Layer:    voplay.CollisionLayerDefault,
				Mask:     voplay.CollisionMaskAll,
			},
		})
	})
	assert(didPanic, "scene3d spawn rollback panics on backend failure")
	assert(s.EntityCount() == 0, "scene3d spawn rollback leaves no entity behind")
	assert(!s.HasPhysics(), "scene3d spawn rollback destroys newly created physics world")
	assert(pb.initCalls == 1, "scene3d spawn rollback initializes physics once")
	assert(len(pb.destroyBodies) == 1 && pb.destroyBodies[0] == 1, "scene3d spawn rollback destroys allocated body")
	assert(len(pb.destroyWorlds) == 1 && pb.destroyWorlds[0] == 91, "scene3d spawn rollback destroys allocated world")
	assert(len(freed.items) == 1 && freed.items[0] == 701, "scene3d spawn rollback frees owned model")

	recovered := s.Spawn(scene3d.EntityDesc{Tag: "recovered"})
	assert(recovered.ID() == 1, "scene3d spawn rollback restores next entity id")
	s.Close()
	assert(len(pb.destroyWorlds) == 1, "scene3d close after rolled back spawn does not destroy absent world twice")
}

func testScene3DTintSemantics() {
	s := scene3d.New()
	defaultTint := s.Spawn(scene3d.EntityDesc{Tag: "default"})
	assert(defaultTint.Tint == voplay.White, "scene3d default tint is white")

	explicitTint := voplay.Color{R: 0.2, G: 0.4, B: 0.6, A: 0.8}
	tinted := s.Spawn(scene3d.EntityDesc{Tag: "tinted", Tint: explicitTint})
	assert(tinted.Tint == explicitTint, "scene3d explicit non-zero tint is preserved")

	transparent := s.Spawn(scene3d.EntityDesc{Tag: "transparent", Tint: voplay.Color{}, TintSet: true})
	assert(transparent.Tint == (voplay.Color{}), "scene3d explicit zero tint is preserved when TintSet")
	s.Close()
}

func testScene3DPicking() {
	scene3DPickTestBounds = map[int]voplay.AABB{
		1: {Min: voplay.Vec3{X: -1, Y: -1, Z: -1}, Max: voplay.Vec3{X: 1, Y: 1, Z: 1}},
		2: {Min: voplay.Vec3{X: -1, Y: -1, Z: -1}, Max: voplay.Vec3{X: 1, Y: 1, Z: 1}},
		3: {Min: voplay.Vec3{X: -1, Y: -1, Z: -1}, Max: voplay.Vec3{X: 1, Y: 1, Z: 1}},
	}
	scene3DPickTestBoundsPresent = map[int]bool{1: true, 2: true, 3: true}
	scene3DPickTestBoundsCalls = 0
	prevBackend := voplay.SetModelBackend(&testPickModelBackend{})
	defer func() {
		voplay.SetModelBackend(prevBackend)
		scene3DPickTestBounds = nil
		scene3DPickTestBoundsPresent = nil
		scene3DPickTestBoundsCalls = 0
	}()

	s := scene3d.New()
	near := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(1), Position: voplay.Vec3{Z: 0}, Tag: "near"})
	far := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(2), Position: voplay.Vec3{Z: -6}, Tag: "far"})
	_ = s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(3), Tag: "hidden", PickMode: scene3d.PickDisabled})

	origin := voplay.Vec3{Z: 5}
	dir := voplay.Vec3{Z: -1}
	hit := s.PickRay(origin, dir, 20)
	assert(hit != nil, "scene3d pick ray returns hit")
	assert(hit.Entity == near, "scene3d pick ray returns nearest visible pickable entity")
	assertFloatNear(hit.Distance, 4.0, 0.000001, "scene3d pick ray distance uses nearest face")

	all := s.PickAllRay(origin, dir, 20)
	assert(len(all) == 2, "scene3d pick all ray returns visible pickable hits")
	assert(all[0].Entity == near, "scene3d pick all ray sorts nearest first")
	assert(all[1].Entity == far, "scene3d pick all ray includes farther hit second")

	filtered := s.PickRayFiltered(origin, dir, 20, func(e *scene3d.Entity) bool {
		return e.Tag == "far"
	})
	assert(filtered != nil && filtered.Entity == far, "scene3d pick ray filter selects matching entity")
	assert(scene3DPickTestBoundsCalls == 2, "scene3d pick caches bounds per model and skips disabled entities")
	s.Close()
}

func testScene3DAttachedSpatialAudio() {
	au := &testAudioBackend{
		nextSourceID: 1,
		positions:    map[int]voplay.Vec3{},
	}
	prevBackend := voplay.SetAudioBackend(au)
	defer voplay.SetAudioBackend(prevBackend)

	s := scene3d.New()
	s.Camera.Position = voplay.Vec3{X: 0, Y: 2, Z: 5}
	s.Camera.Target = voplay.Vec3{X: 0, Y: 2, Z: 0}
	s.Camera.Up = voplay.Vec3{Y: 1}

	e := s.Spawn(scene3d.EntityDesc{Position: voplay.Vec3{X: 1, Y: 2, Z: 3}, Tag: "speaker"})
	e.PlaySound3D(voplay.AudioClipID(7), 0.5)
	assert(au.playedClip == voplay.AudioClipID(7), "scene3d entity play sound forwards clip")
	assertVec3Near(au.playedPos, voplay.Vec3{X: 1, Y: 2, Z: 3}, 0.000001, "scene3d entity play sound forwards position")
	assertFloatNear(au.playedVolume, 0.5, 0.000001, "scene3d entity play sound forwards volume")
	assertFloatNear(au.playedRefDist, 1.0, 0.000001, "scene3d entity play sound uses default ref distance")
	assertFloatNear(au.playedMaxDist, 50.0, 0.000001, "scene3d entity play sound uses default max distance")

	source, err := e.AttachAudioSource(voplay.AudioClipID(8), 0.7, 2.0, 30.0)
	assert(err == nil, "scene3d attach audio source err")
	assert(source == voplay.AudioSourceID(1), "scene3d attach audio source returns created id")
	e.SetPosition(voplay.Vec3{X: 4, Y: 5, Z: 6})
	s.UpdateAudio()
	assert(au.updateCalls == 1, "scene3d update audio calls backend update")
	assertVec3Near(au.positions[1], voplay.Vec3{X: 4, Y: 5, Z: 6}, 0.000001, "scene3d update audio syncs attached source position")
	assertVec3Near(au.listenerPos, s.Camera.Position, 0.000001, "scene3d update audio forwards listener position")
	assertVec3Near(au.listenerForward, voplay.Vec3{X: 0, Y: 0, Z: -1}, 0.000001, "scene3d update audio forwards listener forward")
	assertVec3Near(au.listenerUp, s.Camera.Up, 0.000001, "scene3d update audio forwards listener up")

	e.RemoveAudioSource(source)
	assert(len(au.removed) == 1 && au.removed[0] == 1, "scene3d remove audio source forwards removal")
	_, didPanic := capturePanic(func() {
		e.RemoveAudioSource(source)
	})
	assert(didPanic, "scene3d removing missing audio source panics")

	source2, err := e.AttachAudioSource(voplay.AudioClipID(9), 1.0, 1.0, 10.0)
	assert(err == nil, "scene3d second attach audio source err")
	assert(source2 == voplay.AudioSourceID(2), "scene3d second attach audio source returns next id")
	s.Destroy(e)
	assert(len(au.removed) == 2 && au.removed[1] == 2, "scene3d destroy removes attached audio sources")
	s.Close()
}

func testScene3DOwnedModelLifecycle() {
	freed := &intList{}
	mb := &testFreeModelBackend{freed: freed}
	mb.prev = voplay.SetModelBackend(mb)
	defer voplay.SetModelBackend(mb.prev)

	s := scene3d.New()
	eOwned := s.Spawn(scene3d.EntityDesc{OwnedModel: voplay.ModelID(101)})
	assert(eOwned.Model == voplay.ModelID(101), "scene3d owned model becomes entity model")
	s.Destroy(eOwned)
	assert(len(freed.items) == 1 && freed.items[0] == 101, "scene3d destroy frees owned model")

	eBorrowed := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(102)})
	s.Destroy(eBorrowed)
	assert(len(freed.items) == 1, "scene3d destroy does not free borrowed model")

	s.Spawn(scene3d.EntityDesc{OwnedModel: voplay.ModelID(103)})
	s.Clear()
	assert(len(freed.items) == 2 && freed.items[1] == 103, "scene3d clear frees owned model")

	s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(104), OwnedModel: voplay.ModelID(104)})
	s.Close()
	assert(len(freed.items) == 3 && freed.items[2] == 104, "scene3d close frees owned model when model matches owned model")
}

func testScene3DColliderWithOffset() {
	c := scene3d.Box(2, 3, 4)
	assert(c.Kind() == scene3d.ColliderBox, "scene3d collider kind")
	args := c.Args()
	assertFloatNear(args[0], 2, 0.000001, "scene3d box arg x")
	assertFloatNear(args[1], 3, 0.000001, "scene3d box arg y")
	assertFloatNear(args[2], 4, 0.000001, "scene3d box arg z")
	assertVec3Near(c.Offset(), voplay.Vec3{}, 0.000001, "scene3d box default offset")

	shifted := c.WithOffset(voplay.Vec3{X: 1, Y: 2, Z: 3})
	assertVec3Near(c.Offset(), voplay.Vec3{}, 0.000001, "scene3d box with offset returns copy")
	assertVec3Near(shifted.Offset(), voplay.Vec3{X: 1, Y: 2, Z: 3}, 0.000001, "scene3d box with offset value")

	sphere := scene3d.Sphere(5).WithOffset(voplay.Vec3{Y: -1})
	assert(sphere.Kind() == scene3d.ColliderSphere, "scene3d sphere collider kind")
	args = sphere.Args()
	assertFloatNear(args[0], 5, 0.000001, "scene3d sphere arg radius")
	assertVec3Near(sphere.Offset(), voplay.Vec3{Y: -1}, 0.000001, "scene3d sphere with offset value")
}

func testScene3DEntityHasSkeleton() {
	ab := &testAnimationBackend{}
	prevBackend := scene3d.SetAnimationBackend(ab)
	defer scene3d.SetAnimationBackend(prevBackend)

	s := scene3d.New()
	animated := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(901), Tag: "animated"})
	plain := s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(902), Tag: "plain"})
	marker := s.Spawn(scene3d.EntityDesc{Tag: "marker"})

	assert(animated.HasSkeleton(), "scene3d animated entity reports skeleton")
	assert(!plain.HasSkeleton(), "scene3d plain entity reports no skeleton")
	assert(!marker.HasSkeleton(), "scene3d entity without model reports no skeleton")
	assert(ab.modelInfoCalls == 2, "scene3d HasSkeleton queries modeled entities once")

	assert(animated.HasSkeleton(), "scene3d animated entity cached skeleton result")
	assert(!plain.HasSkeleton(), "scene3d plain entity cached skeleton result")
	assert(ab.modelInfoCalls == 2, "scene3d HasSkeleton reuses cached model info")
	s.Close()
}

func testScene3DPickZeroDirection() {
	scene3DPickTestBounds = map[int]voplay.AABB{
		1: {Min: voplay.Vec3{X: -1, Y: -1, Z: -1}, Max: voplay.Vec3{X: 1, Y: 1, Z: 1}},
	}
	scene3DPickTestBoundsPresent = map[int]bool{1: true}
	scene3DPickTestBoundsCalls = 0
	prevBackend := voplay.SetModelBackend(&testPickModelBackend{})
	defer func() {
		voplay.SetModelBackend(prevBackend)
		scene3DPickTestBounds = nil
		scene3DPickTestBoundsPresent = nil
		scene3DPickTestBoundsCalls = 0
	}()

	s := scene3d.New()
	s.Spawn(scene3d.EntityDesc{Model: voplay.ModelID(1), Tag: "pickable"})
	hit := s.PickRay(voplay.Vec3{}, voplay.Vec3{}, 10)
	assert(hit == nil, "scene3d zero direction pick ray returns nil")
	all := s.PickAllRay(voplay.Vec3{}, voplay.Vec3{}, 10)
	assert(len(all) == 0, "scene3d zero direction pick all ray returns empty slice")
	assert(scene3DPickTestBoundsCalls == 0, "scene3d zero direction pick skips bounds queries")
	s.Close()
}

func testScene2DPhysicsBackend() {
	prev := scene2d.SetPhysicsBackend(nil)
	assert(prev != nil, "scene2d default physics backend is not nil")
	scene2d.SetPhysicsBackend(prev)
}

