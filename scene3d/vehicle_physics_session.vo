package scene3d

const defaultVehiclePhysicsSessionFixedDt = 1.0 / 60.0
const vehiclePhysicsSessionMaxSteps = 8

type VehicleIntentFrame struct {
	FrameID int
	Intent VehicleIntent
	Delta float64
}

type VehiclePhysicsSessionDesc struct {
	Scene *Scene
	Vehicle *Vehicle
	Controller *KartController
	FixedDt float64
	RecordReplay bool
	ReplayContract PhysicsReplayContractIdentity
}

type VehiclePhysicsSession struct {
	Scene *Scene
	Vehicle *Vehicle
	Controller *KartController
	FixedDt float64
	Accumulator float64
	FrameID int
	StepIndex int
	Replay *PhysicsReplayTraceRecorder
	ReplayVehicleIndex int
	LastIntentFrame VehicleIntentFrame
	LastState KartControllerState
	LastTelemetry VehicleTelemetry
	InvalidSampleCount int
	DroppedFixedStepCount int
	ValidationIssues []VehicleTelemetryIssue
	LastPacketHash int
}

func NewVehiclePhysicsSession(desc VehiclePhysicsSessionDesc) *VehiclePhysicsSession {
	fixedDt := desc.FixedDt
	if fixedDt <= 0 {
		fixedDt = defaultVehiclePhysicsSessionFixedDt
	}
	session := &VehiclePhysicsSession{Scene: desc.Scene, Vehicle: desc.Vehicle, Controller: desc.Controller, FixedDt: fixedDt}
	if desc.RecordReplay {
		if desc.Scene != nil {
			desc.Scene.SetPhysicsBackendCommandEventCapture(true)
		}
		session.Replay = NewPhysicsReplayTraceRecorder(fixedDt)
		session.Replay.BindContract(desc.ReplayContract)
	}
	return session
}

func (s *VehiclePhysicsSession) Step(delta float64, intent VehicleIntent) VehicleTelemetry {
	if s == nil {
		return VehicleTelemetry{}
	}
	if delta < 0 {
		delta = 0
	}
	if s.FixedDt <= 0 {
		s.FixedDt = defaultVehiclePhysicsSessionFixedDt
	}
	s.Accumulator += delta
	steps := 0
	if s.Accumulator >= s.FixedDt && s.Scene != nil && !s.Scene.physicsWorld.snapshot.ready {
		s.Scene.syncVehicles()
	}
	for s.Accumulator >= s.FixedDt && steps < vehiclePhysicsSessionMaxSteps {
		s.StepIndex++
		s.FrameID = s.StepIndex
		s.applyIntentForFixedStep(intent)
		s.runSceneFixedStep()
		s.Accumulator -= s.FixedDt
		steps++
	}
	if steps == vehiclePhysicsSessionMaxSteps && s.Accumulator >= s.FixedDt {
		s.DroppedFixedStepCount += int(s.Accumulator / s.FixedDt)
		s.Accumulator = 0
	}
	if s.Vehicle != nil {
		s.captureTelemetry()
	}
	return s.LastTelemetry
}

func (s *VehiclePhysicsSession) StepFleet(delta float64, sessions []*VehiclePhysicsSession, intents []VehicleIntent) []VehicleTelemetry {
	if s == nil {
		return []VehicleTelemetry{}
	}
	if delta < 0 {
		delta = 0
	}
	if s.FixedDt <= 0 {
		s.FixedDt = defaultVehiclePhysicsSessionFixedDt
	}
	s.Accumulator += delta
	if s.Accumulator >= s.FixedDt && s.Scene != nil && !s.Scene.physicsWorld.snapshot.ready {
		s.Scene.syncVehicles()
	}
	steps := 0
	for s.Accumulator >= s.FixedDt && steps < vehiclePhysicsSessionMaxSteps {
		s.StepIndex++
		s.FrameID = s.StepIndex
		for i, session := range sessions {
			if session == nil {
				continue
			}
			session.FixedDt = s.FixedDt
			session.FrameID = s.FrameID
			session.StepIndex = s.StepIndex
			intent := VehicleIntent{}
			if i < len(intents) {
				intent = intents[i]
			}
			session.applyIntentForFixedStep(intent)
		}
		s.runSceneFixedStep()
		s.Accumulator -= s.FixedDt
		steps++
	}
	if steps == vehiclePhysicsSessionMaxSteps && s.Accumulator >= s.FixedDt {
		s.DroppedFixedStepCount += int(s.Accumulator / s.FixedDt)
		s.Accumulator = 0
	}
	telemetry := []VehicleTelemetry{}
	for _, session := range sessions {
		if session == nil || session.Vehicle == nil {
			telemetry = append(telemetry, VehicleTelemetry{})
			continue
		}
		session.captureTelemetry()
		telemetry = append(telemetry, session.LastTelemetry)
	}
	return telemetry
}

func (s *VehiclePhysicsSession) applyIntentForFixedStep(intent VehicleIntent) KartControllerState {
	if s == nil {
		return KartControllerState{}
	}
	normalized := intent.Normalized()
	s.LastIntentFrame = VehicleIntentFrame{FrameID: s.FrameID, Intent: normalized, Delta: s.FixedDt}
	if s.Controller != nil {
		s.LastState = s.Controller.UpdateIntentFromSyncedState(normalized, s.FixedDt)
	} else if s.Vehicle != nil {
		s.Vehicle.updateIntentFromSyncedState(normalized, s.FixedDt)
	}
	return s.LastState
}

func (s *VehiclePhysicsSession) runSceneFixedStep() {
	if s == nil || s.Scene == nil {
		return
	}
	s.Scene.RunPhysicsFixedStep(s.FixedDt)
}

func (s *VehiclePhysicsSession) captureTelemetry() {
	if s == nil || s.Vehicle == nil {
		return
	}
	s.LastTelemetry = s.Vehicle.Telemetry()
	s.InvalidSampleCount = s.LastTelemetry.InvalidSampleCount
	s.ValidationIssues = s.LastTelemetry.ValidationIssues(s.LastIntentFrame.Intent, VehicleTelemetryBudget{})
	s.LastPacketHash = s.LastTelemetry.BackendApplyHash
	if s.Replay != nil {
		commands := []PhysicsBackendCommandEvent{}
		if s.Scene != nil {
			commands = s.Scene.PhysicsBackendCommandEventsAfter(s.Replay.LastBackendCommandSequence())
		}
		s.Replay.RecordVehicleAt(s.FrameID, s.ReplayVehicleIndex, s.LastIntentFrame.Intent, s.LastTelemetry, commands)
	}
}

func (s *VehiclePhysicsSession) Trace() PhysicsReplayTrace {
	if s == nil || s.Replay == nil {
		return PhysicsReplayTrace{}
	}
	return s.Replay.Trace()
}

func FixedPhysicsStep(scene *Scene, dt float64) {
	if scene == nil {
		return
	}
	scene.StepAndSyncPhysics(dt)
}

func (s *Scene) RunPhysicsFixedStep(dt float64) {
	if s == nil {
		return
	}
	s.StepAndSyncPhysics(dt)
}
