package scene3d

import (
	"github.com/vo-lang/vopack/scene3dmap"
)

func validateMapAsset(asset *MapAsset) error {
	return scene3dmap.Validate(asset)
}

func validateMapTerrain(terrain MapTerrain) error {
	return scene3dmap.ValidateTerrain(terrain)
}

func MapAssetDependencies(asset *MapAsset, baseDir string) []MapDependency {
	return scene3dmap.Dependencies(asset, baseDir)
}
