		",\"fixed\":{" +
		"\"totalMs\":" +
		perfSummaryJSONFloat(fixed.TotalMs) +
		",\"peakTotalMs\":" +
		perfSummaryJSONFloat(fixed.PeakTotalMs) +
		",\"slowFrames\":" +
		strconv.Itoa(fixed.SlowFrames) +
		",\"frames\":" +
		strconv.Itoa(fixed.Frames) +
